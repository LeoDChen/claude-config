) { $dism } else { Write-Host \"DISM 中未找到 Copilot 功能\" }\n\n# 4. 检查任务栏注册表\nWrite-Host \"`n=== 检查 Copilot 任务栏设置 ===\"\n$taskbarKey = \"HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\"\n$taskbarVal = Get-ItemProperty $taskbarKey -Name \"ShowCopilotButton\" -ErrorAction SilentlyContinue\nif ($taskbarVal) { Write-Host \"ShowCopilotButton = $($taskbarVal.ShowCopilotButton)\" } else { Write-Host \"未找到 ShowCopilotButton 键\" }\n","userModified":false},"sourceToolAssistantUUID":"549fe8ab-0a08-42fd-92c8-a97036ef55a0","userType":"external","entrypoint":"claude-vscode","cwd":"D:\\ClaudeCode workspace","sessionId":"a5a364d3-32e3-4c52-8950-4b420638b25f","version":"2.1.143","gitBranch":"main"}
