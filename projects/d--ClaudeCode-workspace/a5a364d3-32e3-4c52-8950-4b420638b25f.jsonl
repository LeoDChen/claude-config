h $edgeCopilotPath -Name \"HubsSidebarEnabled\" -Value 0 -Type DWord -Force -ErrorAction SilentlyContinue","+Write-Host \"  Edge Copilot sidebar: DISABLED\" -ForegroundColor Green","+","+# Group Policy: Turn off Windows Copilot","+$gpPath = \"HKLM:\\Software\\Policies\\Microsoft\\Windows\\WindowsCopilot\"","+if (-not (Test-Path $gpPath)) { New-Item -Path $gpPath -Force | Out-Null }","+Set-ItemProperty -Path $gpPath -Name \"TurnOffWindowsCopilot\" -Value 1 -Type DWord -Force -ErrorAction SilentlyContinue","+Write-Host \"  Windows Copilot (Group Policy): TURNED OFF\" -ForegroundColor Green","+$removed = $true","+","+# ---- 4. Scheduled tasks ----","+Write-Host \"\"","+Write-Host \"[4/4] Checking for Copilot scheduled tasks...\" -ForegroundColor Yellow","+$tasks = Get-ScheduledTask | Where-Object { $_.TaskName -match 'copilot|Copilot' }","+if ($tasks) {","+    foreach ($t in $tasks) {","+        Write-Host \"  Disabling: $($t.TaskName)\" -ForegroundColor Gray","+        Disable-ScheduledTask -TaskName $t.TaskName -ErrorAction SilentlyContinue","+        $removed = $true","+    }"," } else {","-    Write-Host \"注册表中未找到 Copilot\"","+    Write-Host \"  No Copilot scheduled tasks found.\" -ForegroundColor Gray"," }"," ","-# 3. DISM 查找 Windows 功能中的 Copilot","-Write-Host \"`n=== Windows 功能中的 Copilot (DISM) ===\"","-$dism = dism /online /get-features /format:list 2>&1 | Select-String -Pattern \"Copilot\" -CaseSensitive:$false","-if ($dism) { $dism } else { Write-Host \"DISM 中未找到 Copilot 功能\" }","-","-# 4. 检查任务栏注册表","-Write-Host \"`n=== 检查 Copilot 任务栏设置 ===\"","-$taskbarKey = \"HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\"","-$taskbarVal = Get-ItemProperty $taskbarKey -Name \"ShowCopilotButton\" -ErrorAction SilentlyContinue","-if ($taskbarVal) { Write-Host \"ShowCopilotButton = $($taskbarVal.ShowCopilotButton)\" } else { Write-Host \"未找到 ShowCopilotButton 键\" }","+# ---- Summary ----","+Write-Host \"\"","+Write-Host \"==============================