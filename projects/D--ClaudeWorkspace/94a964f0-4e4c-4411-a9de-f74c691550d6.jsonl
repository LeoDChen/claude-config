gistering Windows Photo Viewer...\"\nWrite-Host \"Shell command set.\"\n\n# Now set file associations using ftype/assoc for reliability\n$extensions = @('.png', '.jpg', '.jpeg', '.bmp', '.gif')\n$photoviewerCmd = \"rundll32.exe `\"%ProgramFiles%\\Windows Photo Viewer\\PhotoViewer.dll`\", ImageView_Fullscreen %1\"\n\nforeach ($ext in $extensions) {\n    $extName = \"PhotoViewer$ext\"\n    $extName = $extName.Replace('.', '')\n\n    # Set assoc\n    & cmd /c \"assoc $ext=$extName 2>&1\" | Out-Null\n\n    # Set ftype\n    & cmd /c \"ftype $extName=$photoviewerCmd 2>&1\" | Out-Null\n\n    Write-Host \"  $ext -> Windows Photo Viewer\"\n}\n\n# Clear icon cache\n$iconCache = \"$env:LOCALAPPDATA\\IconCache.db\"\nif (Test-Path $iconCache) { Remove-Item $iconCache -Force }\n$thumbCache = \"$env:LOCALAPPDATA\\Microsoft\\Windows\\Explorer\\thumbcache_*.db\"\nRemove-Item $thumbCache -Force -ErrorAction SilentlyContinue\n\n# Restart Explorer\nStop-Process -Name explorer -Force\nStart-Sleep -Seconds 2\nStart-Process explorer.exe\n\nWrite-Host \"\"\nWrite-Host \"Done! Double-click any image now opens with Windows Photo Viewer.\"\nWrite-Host \"Right-click -> Open with still allows choosing other apps.\"\n","userModified":false},"sourceToolAssistantUUID":"c0beb932-698e-4a4b-97ff-f6c546ca7331","userType":"external","entrypoint":"claude-vscode","cwd":"D:\\ClaudeWorkspace","sessionId":"94a964f0-4e4c-4411-a9de-f74c691550d6","version":"2.1.143","gitBranch":"main"}
