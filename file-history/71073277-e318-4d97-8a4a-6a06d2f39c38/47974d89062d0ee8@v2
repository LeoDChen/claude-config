      <div style="font-size:28px;font-weight:700;color:var(--accent);">37</div>
      <div class="label">活跃客户</div>
    </div>
    <div style="flex:1;min-width:100px;background:#fef2f2;border-radius:8px;padding:16px;text-align:center;">
      <div style="font-size:28px;font-weight:700;color:#dc2626;">5</div>
      <div class="label">🚨 紧急待处理</div>
    </div>
    <div style="flex:1;min-width:100px;background:#fffbeb;border-radius:8px;padding:16px;text-align:center;">
      <div style="font-size:28px;font-weight:700;color:#d97706;">8</div>
