const COL_KEY_SET = new Set(COLUMNS.map((c) => c.key));

// 将阶段映射到列 key
function stageColKey(stage) {
  if (COL_KEY_SET.has(stage)) return stage;
  if (stage === "售后" || stage === "待返单") return "其他";
  return "其他";
}

// ═══════════════════════════════════════════════════════
// 纵轴：紧急度（4 行）
// ═══════════════════════════════════════════════════════
const URGENCY = {
  RED:    { key: "red",    label: "需立即处理", dot: "red",    icon: "🔴" },
  YELLOW: { key: "yellow", label: "需定时关注", dot: "yellow", icon: "🟡" },
  GREY:   { key: "grey",   label: "正常流转",   dot: "grey",   icon: "⚪" },
  FROZEN: { key: "frozen", label: "冷冻",       dot: "grey",   icon: "❄️" },
};

/**
 * 判定客户紧急度
 *   - S3(该推进了) / S4(该催款了,非observe) → RED
 *   - S1/S2/S5a/S6/S7/S8/S9 → YELLOW
 *   - 冷层 → FROZEN
 *   - 其余 → GREY
 */
function classifyUrgency(factors) {
  if (!factors || factors.length === 0) return "grey";
  for (const f of factors) {
    const code = (f.factor || "").split("(")[0].trim();
    if (code === "S3 该推进了") return "red";
    if (code === "S4 该催款了" && !f.observeMode) return "red";
  }
  // S4(观察) 和其他因子均为 yellow
  for (const f of factors) {
    const code = (f.factor || "").split("(")[0].trim();
    if (/^S\d/.test(code)) return "yellow";
  }
  return "grey";
}

