        html += `  <div class="cell"></div>\n`;
        continue;
      }

      // 正常流转：折叠显示
      if (u.key === "grey") {
        const show = bucket.slice(0, 3);
        const rest = bucket.length - 3;
        const chips = show.map((c) => `<span class="customer-chip chip-grey" onclick="openModal('${esc(c.cid)}')">${esc(c.name)}</span>`).join("");
        const more = rest > 0 ? `<span class="customer-chip chip-grey">+${rest}</span>` : "";
        html += `  <div class="cell">${chips}${more}</div>\n`;
        continue;
      }

      // RED / YELLOW：展示所有芯片
      const chipClass = u.key === "red" ? "chip-red" : "chip-yellow";
      const chips = bucket.map((c) => {
        const badge = c.factors.length > 0 ? shortBadge(c.factors[0]) : "";
        const tierMark = (c.tier === "S" || c.tier === "A") ? `<span class="chip-tier-${c.tier.toLowerCase()}">${c.tier}</span>` : "";
        return `<span class="customer-chip ${chipClass}" onclick="openModal('${esc(c.cid)}')"><span class="chip-dot ${dotClass}"></span>${esc(c.name)}${tierMark}${badge}</span>`;
      }).join("\n    ");
      html += `  <div class="cell">${chips}</div>\n`;
    }
  }

  html += `</div>
<!-- Overlay -->
<div class="overlay" id="overlay" onclick="if(event.target===this)closeModal()">
<div class="modal" id="modal"></div>
</div>

<script>
const CARDS = ${JSON.stringify(cards, null, 0)};
const COUNTRY_CN = ${JSON.stringify(COUNTRY_CN)};
const COLUMNS = ${JSON.stringify(COLUMNS)};
const FACTOR_DESC = ${JSON.stringify(FACTOR_DESC)};

function openModal(cid) {
  const c = CARDS.find(x => x.cid === cid);
  if (!c) return;
  let html = '';
  html += '<div class="modal-header"><h2>' + esc(c.name) + '</h2><button class="modal-close" onclick="closeModal()">✕</button></div>';
  html += '<div class="modal-body">';

  // Frontmatter
  html += '<div class="fm-grid">';
  for (const [k,v] of [['国家',c.countryCN||c.country],['阶段',c.stage],['等级',c.tier+'级'],['最后联系',c.daysSince!==null?c.daysSince+'天前':'?']]) {
    html += '<div class="fm-item"><div class="fm-label">'+k+'</div><div class="fm-value">'+esc(String(v))+'</div></div>';
  }
  if (c.firstContact) html += '<div class="fm-item"><div class="fm-label">首次联系</div><div class="fm-value">'+c.firstContact+'</div></div>';
  html += '</div>';

  // Driver factors
  if (c.factors && c.factors.length) {
    html += '<div class="section"><div class="section-title">📋 驱动因子</div><div class="driver-list">';
    for (const f of c.factors) {
      const fd = factorDesc(f);
      const cls = fd.level==='red'?'driver-item-red':'driver-item-yellow';
      const icon = fd.level==='red'?'🔴':'🟡';
      html += '<div class="driver-item '+cls+'"><span class="driver-icon">'+icon+'</span><div><strong>'+esc(fd.title)+'</strong><div style="color:#999;font-size:0.85em;margin-top:2px;">'+esc(fd.detail)+'</div></div></div>';
    }
    html += '</div></div>';
  } else {
    html += '<div class="section"><div class="section-title">📋 驱动因子</div><div class="info-note">无活跃因子。该客户在正常流转中。</div></div>';
  }

  // Chat / key numbers from brief
  if (c.hasBrief) {
    if (c.talkSummary) {
      html += '<div class="section"><div class="section-title">💬 聊到哪了</div><div class="chat-snippet">'+esc(c.talkSummary)+'</div></div>';
    }
    if (c.keyNums && c.keyNums.length) {
      html += '<div class="section"><div class="section-title">🔢 关键数字</div>';
      for (const n of c.keyNums) html += '<div class="key-num">'+esc(n)+'</div>';
      html += '</div>';
    }
    if (c.nextStep) {
      html += '<div class="section"><div class="section-title">→ 下一步</div><div style="font-size:0.88em;line-height:1.6;white-space:pre-line">'+esc(c.nextStep)+'</div></div>';
    }
  } else {
    html += '<div class="info-note">📝 暂无状态卡。运行 /okki 深度分析创建。</div>';
  }

  html += '</div>';
  html += '<div class="modal-footer">路径: ' + (c.briefFile || '未建卡') + ' | 数据源: factor_baselines + soon_layer_cards</div>';

  document.getElementById('modal').innerHTML = html;
  document.getElementById('overlay').classList.add('show');
}

function factorDesc(f) {
  var base = (f.factor||'').split('(')[0].trim();
  var entry = FACTOR_DESC[base] || FACTOR_DESC[f.factor] || {title:f.factor,level:'yellow'};
  var detail = (f.days||'?')+'天前基线('+(f.baseline||'?')+')';
  if (f.rhythmDay) detail += '，节奏第'+f.rhythmDay+'天';
  if (f.observeMode) detail = '观察模式 | '+detail;
  if (f.priority==='high') detail = '⚠ 高优先级 | '+detail;
  return {title:entry.title, level:entry.level, detail:detail};
}

function closeModal() {
  document.getElementById('overlay').classList.remove('show');
}

function esc(s) {
  if (typeof s !== 'string') return s;
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

document.addEventListener('keydown', e => { if (e.key==='Escape') closeModal(); });
</script>

</body>
</html>`;

  return html;
}

function shortBadge(f) {
  const code = (f.factor || "").split("(")[0].trim();
  const map = {
    "S1 该深挖需求了": "深挖", "S2 该追问了": "追问", "S3 该推进了": "推进",
    "S4 该催款了": "催款", "S5a 该更新进度了": "进度", "S6 该更新物流了": "物流",
    "S7a 该回访了": "回访", "S7b 该推返单了": "返单", "S8 该收尾了": "收尾", "S9 该接触了": "接触",
  };
  const tag = map[code] || "待办";
  return `<span class="chip-badge">${tag}</span>`;
}

function esc(s) {
  if (typeof s !== "string") return String(s);
  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

// ═══════════════════════════════════════════════════════
// Markdown 表格（兼容旧模式）
// ═══════════════════════════════════════════════════════

function renderMarkdown(cards) {
  const active = cards.filter((c) => c.urgencyKey !== "frozen");
  const counts = { red: 0, yellow: 0, grey: 0, frozen: 0 };
  for (const c of cards) counts[c.urgencyKey] = (counts[c.urgencyKey] || 0) + 1;

  let md = `# OKKI 客户看板\n\n`;
  md += `> ${TODAY} | 🔴需立即处理:${counts.red} 🟡需定时关注:${counts.yellow} ⚪正常:${counts.grey} ❄️冷冻:${counts.frozen}\n\n`;
  md += `| 客户 | 国家 | 等级 | 阶段 | 最后联系 | 驱动因子 | 下一步 |\n`;
  md += `|------|------|:---:|------|----------|----------|--------|\n`;

  const order = ["red", "yellow", "grey"];
  let lastU = "";
  for (const u of order) {
    for (const c of active) {
      if (c.urgencyKey !== u) continue;
      if (c.urgencyKey !== lastU) {
        lastU = c.urgencyKey;
        const label = URGENCY[u.toUpperCase()] ? URGENCY[u.toUpperCase()].label : u;
        md += `| **── ${label} ──** | | | | | | |\n`;
      }
      const factorNames = c.factors.map((f) => (f.factor || "").split("(")[0].trim().replace("S1 ", "").replace("S3 ", "").replace("S4 ", "").replace("S5a ", "")).join(" · ") || "—";
      const daysStr = c.daysSince !== null ? `${c.daysSince}天前` : "?";
      md += `| ${c.name} | ${c.countryCN} | ${c.tier} | ${c.stage} | ${daysStr} | ${factorNames} | ${c.nextStep || "—"} |\n`;
    }
  }
  return md;
}

