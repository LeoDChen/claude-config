  for (const u of Object.values(URGENCY)) {
    matrix[u.key] = {};
    for (const col of COLUMNS) matrix[u.key][col.key] = [];
  }
  for (const c of cards) {
    const bucket = matrix[c.urgencyKey];
    if (bucket && bucket[c.colKey]) bucket[c.colKey].push(c);
  }

  const counts = {};
  for (const c of cards) counts[c.urgencyKey] = (counts[c.urgencyKey] || 0) + 1;
  const frozenList = cards.filter(c => c.urgencyKey === "frozen");

  const now = TODAY;

  let html = `<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OKKI 客户状态看板 — ${now}</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif; background: #f5f5f5; padding: 20px; color: #333; }
  h1 { font-size: 1.2em; margin-bottom: 2px; }
  .subtitle { color: #999; font-size: 0.78em; margin-bottom: 16px; }
  .summary-bar { display: flex; gap: 16px; margin-bottom: 14px; font-size: 0.82em; align-items: center; }
  .summary-bar span { padding: 4px 12px; border-radius: 14px; background: #fff; border: 1px solid #eee; }
  .summary-bar strong { font-size: 1.2em; }

  .matrix-wrap { overflow-x: auto; }
  .matrix { display: grid; gap: 1px; background: #e0e0e0; border-radius: 10px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.04); min-width: 960px; }

  .cell { background: #fff; padding: 8px 10px; min-height: 52px; display: flex; flex-wrap: wrap; gap: 4px; align-content: start; align-items: start; }
  .cell-header { background: #fafafa; padding: 8px 6px; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.75em; color: #666; text-align: center; }
  .row-label { background: #fafafa; padding: 8px 10px; display: flex; align-items: center; gap: 6px; font-size: 0.76em; font-weight: 600; white-space: nowrap; }

  .customer-chip { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px; border-radius: 13px; font-size: 0.73em; cursor: pointer; border: 1px solid transparent; white-space: nowrap; transition: all .12s; }
  .customer-chip:hover { transform: translateY(-1px); box-shadow: 0 2px 8px rgba(0,0,0,.12); }
  .chip-red { background: #ffebee; border-color: #ffcdd2; color: #b71c1c; }
  .chip-yellow { background: #fff8e1; border-color: #ffecb3; color: #e65100; }
  .chip-grey { background: #f5f5f5; border-color: #eee; color: #888; }
  .chip-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
  .chip-dot-red { background: #d32f2f; }
  .chip-dot-yellow { background: #f57c00; }
  .chip-dot-grey { background: #bbb; }
  .chip-badge { font-size: 0.68em; padding: 1px 4px; border-radius: 6px; background: rgba(0,0,0,.06); }
  .chip-tier-s { background: #ffd700; color: #5d4037; font-size: 0.6em; padding: 0px 3px; border-radius: 4px; margin-left: 1px; }
  .chip-tier-a { background: #c8e6c9; color: #2e7d32; font-size: 0.6em; padding: 0px 3px; border-radius: 4px; margin-left: 1px; }

  .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 1000; justify-content: center; align-items: center; }
  .overlay.show { display: flex; }
  .modal { background: #fff; border-radius: 14px; box-shadow: 0 8px 48px rgba(0,0,0,.2); width: 700px; max-height: 85vh; display: flex; flex-direction: column; overflow: hidden; animation: modalIn .18s ease; }
  @keyframes modalIn { from { opacity:0; transform:scale(.96) translateY(8px); } to { opacity:1; transform:scale(1) translateY(0); } }
  .modal-header { padding: 18px 24px; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
  .modal-header h2 { font-size: 1.15em; }
  .modal-close { background: none; border: none; font-size: 1.4em; cursor: pointer; color: #999; padding: 6px 10px; border-radius: 6px; line-height: 1; }
  .modal-close:hover { background: #f0f0f0; }
  .modal-body { padding: 20px 24px; overflow-y: auto; flex: 1; font-size: 0.88em; line-height: 1.6; }
  .modal-footer { padding: 14px 24px; border-top: 1px solid #f0f0f0; display: flex; gap: 8px; flex-shrink: 0; }

  .btn { padding: 7px 18px; border-radius: 6px; border: 1px solid #ddd; font-size: 0.84em; cursor: pointer; background: #fff; transition: .12s; }
  .btn:hover { background: #f5f5f5; }
  .btn-primary { background: #1976d2; color: #fff; border-color: #1976d2; }
  .btn-primary:hover { background: #1565c0; }

  .fm-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 10px; margin-bottom: 18px; }
  .fm-item { background: #fafafa; border-radius: 8px; padding: 10px 14px; }
  .fm-label { color: #999; font-size: 0.7em; text-transform: uppercase; letter-spacing: 0.5px; }
  .fm-value { font-weight: 600; font-size: 0.95em; margin-top: 3px; }

  .section { margin-bottom: 16px; }
  .section-title { font-weight: 600; font-size: 0.8em; color: #888; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; text-transform: uppercase; letter-spacing: 0.5px; }

  .driver-list { display: flex; flex-direction: column; gap: 6px; }
  .driver-item { display: flex; gap: 10px; padding: 10px 14px; border-radius: 8px; font-size: 0.9em; align-items: flex-start; }
  .driver-item-red { background: #fff5f5; border: 1px solid #ffcdd2; }
  .driver-item-yellow { background: #fffdf5; border: 1px solid #ffecb3; }
  .driver-icon { font-size: 1.15em; flex-shrink: 0; margin-top: 1px; }

  .chat-snippet { background: #fafafa; border-radius: 8px; padding: 10px 14px; font-size: 0.86em; }
  .chat-line { padding: 4px 0; display: flex; gap: 10px; align-items: baseline; }
  .chat-who { font-weight: 600; flex-shrink: 0; min-width: 20px; }
  .chat-who-me { color: #1976d2; }
  .chat-who-cust { color: #d32f2f; }
  .chat-time { color: #bbb; font-size: 0.78em; flex-shrink: 0; min-width: 45px; }

  .key-num { background: #f5f5f5; border-radius: 6px; padding: 7px 12px; margin-bottom: 4px; font-size: 0.85em; }
  .info-note { background: #fff9c4; border-radius: 6px; padding: 8px 12px; font-size: 0.82em; color: #666; }

  .frozen-row { background: #fafafa; padding: 8px 14px; font-size: 0.74em; color: #999; display: flex; flex-wrap: wrap; gap: 4px; align-items: center; }
  .frozen-chip { cursor: default; opacity: 0.5; }
  .frozen-chip:hover { transform: none; box-shadow: none; }

  .legend { font-size: 0.75em; color: #999; margin-top: 14px; display: flex; gap: 20px; flex-wrap: wrap; }
</style>
</head>
<body>

<h1>OKKI 客户状态看板</h1>
<p class="subtitle">横轴：生命周期阶段 → ｜ 纵轴：紧急度 ｜ 点击客户卡片查看详情 ｜ ${now}</p>

<div class="summary-bar">
  <span>🔴 需立即处理 <strong>${counts.red || 0}</strong></span>
  <span>🟡 需定时关注 <strong>${counts.yellow || 0}</strong></span>
  <span>⚪ 正常流转 <strong>${counts.grey || 0}</strong></span>
  <span>❄️ 冷冻 <strong>${counts.frozen || 0}</strong></span>
</div>

<div class="matrix-wrap">
<div class="matrix" style="grid-template-columns: 80px repeat(${COLUMNS.length}, 1fr);">
  <div class="cell-header"></div>
${COLUMNS.map(col => `  <div class="cell-header">${col.icon} ${col.label}</div>`).join("\n")}
`;

  for (const u of [URGENCY.RED, URGENCY.YELLOW, URGENCY.GREY, URGENCY.FROZEN]) {
    const dotClass = `chip-dot-${u.dot}`;
    const opacity = u.key === "frozen" ? ' style="opacity:0.45"' : "";

    if (u.key === "frozen") {
      const show = frozenList.slice(0, 10);
      const rest = frozenList.length - 10;
      const chips = show.map(c => `<span class="customer-chip chip-grey frozen-chip">${esc(c.name)}</span>`).join("\n    ");
      const more = rest > 0 ? `<span class="customer-chip chip-grey frozen-chip">+${rest}人</span>` : "";
      html += `  <div class="row-label"${opacity}><span class="chip-dot ${dotClass}"></span>${u.icon} ${u.label}</div>\n`;
      html += `  <div class="frozen-row" style="grid-column: span ${COLUMNS.length};">${chips}${more}</div>\n`;
      continue;
    }

    html += `  <div class="row-label"${opacity}><span class="chip-dot ${dotClass}"></span>${u.icon} ${u.label}</div>\n`;

    for (const col of COLUMNS) {
      const bucket = matrix[u.key][col.key] || [];
      if (bucket.length === 0) {
        html += `  <div class="cell"></div>\n`;
        continue;
      }

      if (u.key === "grey") {
        // 正常流转：展示更多芯片，超过20个才折叠
        const maxShow = 20;
        const show = bucket.slice(0, maxShow);
        const rest = bucket.length - maxShow;
        const chips = show.map(c =>
          `<span class="customer-chip chip-grey" onclick="openModal('${esc(c.cid)}')">${esc(c.name)}</span>`
        ).join("");
        const more = rest > 0 ? `<span class="customer-chip chip-grey">+${rest}</span>` : "";
        html += `  <div class="cell">${chips}${more}</div>\n`;
      } else {
        const chipClass = u.key === "red" ? "chip-red" : "chip-yellow";
        const chips = bucket.map(c => {
          const badge = c.factors.length > 0 ? makeBadge(c.factors[0], c.daysSince, c.paymentConfirmed) : "";
          const tierMark = (c.tier === "S" || c.tier === "A")
            ? `<span class="chip-tier-${c.tier.toLowerCase()}">${c.tier}</span>` : "";
          return `<span class="customer-chip ${chipClass}" onclick="openModal('${esc(c.cid)}')"><span class="chip-dot ${dotClass}"></span>${esc(c.name)}${tierMark}<span class="chip-badge">${badge}</span></span>`;
        }).join("\n    ");
        html += `  <div class="cell">${chips}</div>\n`;
      }
    }
  }

  html += `</div>
</div>

<div class="legend">
  <span>🔴 需立即处理 = ${URGENCY.RED.desc}</span>
  <span>🟡 需定时关注 = ${URGENCY.YELLOW.desc}</span>
  <span>⚪ 正常流转 = ${URGENCY.GREY.desc}</span>
  <span>❄️ 冷冻 = ${URGENCY.FROZEN.desc}</span>
</div>

<div class="overlay" id="overlay" onclick="if(event.target===this)closeModal()">
<div class="modal" id="modal"></div>
</div>

<script>
var CARDS = ${JSON.stringify(cards)};

function openModal(cid) {
  var c = CARDS.find(function(x){ return x.cid === cid; });
  if (!c) return;
  var h = '';
  h += '<div class="modal-header"><h2>' + esc(c.name) + '</h2><button class="modal-close" onclick="closeModal()">✕</button></div>';
  h += '<div class="modal-body">';

  // Frontmatter
  h += '<div class="fm-grid">';
  var fields = [
    ['国家', c.countryCN || c.country],
    ['阶段', c.stage],
    ['等级', c.tier + '级'],
    ['最后联系', c.daysSince !== null ? c.daysSince + '天前' : '?']
  ];
  for (var i = 0; i < fields.length; i++) {
    h += '<div class="fm-item"><div class="fm-label">' + fields[i][0] + '</div><div class="fm-value">' + esc(String(fields[i][1])) + '</div></div>';
  }
  if (c.firstContact) {
    h += '<div class="fm-item"><div class="fm-label">首次联系</div><div class="fm-value">' + c.firstContact + '</div></div>';
  }
  h += '</div>';

  // Driver factors (服务端预生成)
  if (c.richDrivers && c.richDrivers.length) {
    h += '<div class="section"><div class="section-title">📋 驱动因子</div><div class="driver-list">';
    for (var j = 0; j < c.richDrivers.length; j++) {
      var dr = c.richDrivers[j];
      var cls = dr.level === 'red' ? 'driver-item-red' : 'driver-item-yellow';
      var icon = dr.level === 'red' ? '🔴' : '🟡';
      h += '<div class="driver-item ' + cls + '"><span class="driver-icon">' + icon + '</span><div><strong>' + esc(dr.title) + '</strong><div style="color:#999;font-size:0.85em;margin-top:2px;">' + esc(dr.detail) + '</div></div></div>';
    }
    h += '</div></div>';
  } else if (c.urgencyKey === 'red') {
    h += '<div class="section"><div class="section-title">📋 驱动因子</div><div class="info-note">⚠️ 该客户标记为需立即处理（状态卡热度=NOW），但未命中因子节奏天。请检查状态卡确认紧急原因。</div></div>';
  } else if (c.urgencyKey === 'yellow') {
    h += '<div class="section"><div class="section-title">📋 驱动因子</div><div class="info-note">📌 该客户标记为需关注（状态卡热度=NOW/SOON），但未命中因子节奏天。可能是刚联系过或等待客户行动中。</div></div>';
  } else if (c.urgencyKey !== 'frozen') {
    h += '<div class="section"><div class="section-title">📋 驱动因子</div><div class="info-note">无活跃因子。该客户在正常流转中，暂无行动信号。</div></div>';
  }

  // Chat lines (中文摘要)
  if (c.chatLinesCN && c.chatLinesCN.length) {
    h += '<div class="section"><div class="section-title">💬 聊到哪了</div><div class="chat-snippet">';
    for (var k = 0; k < c.chatLinesCN.length; k++) {
      var cl = c.chatLinesCN[k];
      var whoClass = cl.who === '我方' ? 'chat-who-me' : 'chat-who-cust';
      h += '<div class="chat-line"><span class="chat-who ' + whoClass + '">' + esc(cl.who) + '</span><span class="chat-time">' + esc(cl.time) + '</span>' + esc(cl.action) + '</div>';
    }
    h += '</div></div>';
  } else if (c.chatLines && c.chatLines.length) {
    // 降级：无中文摘要时显示原文
    h += '<div class="section"><div class="section-title">💬 聊到哪了</div><div class="chat-snippet">';
    for (var k = 0; k < c.chatLines.length; k++) {
      var cl2 = c.chatLines[k];
      var whoClass2 = cl2.who === 'me' ? 'chat-who-me' : 'chat-who-cust';
      h += '<div class="chat-line"><span class="chat-who ' + whoClass2 + '">' + (cl2.who === 'me' ? '我' : '客') + '</span><span class="chat-time">' + cl2.time + '</span>' + esc(cl2.text) + '</div>';
    }
    h += '</div></div>';
  }

  // Key numbers
  if (c.keyNums && c.keyNums.length) {
    h += '<div class="section"><div class="section-title">🔢 关键数字</div>';
    for (var m = 0; m < c.keyNums.length; m++) {
      h += '<div class="key-num">' + esc(c.keyNums[m]) + '</div>';
    }
    h += '</div>';
  }

  // Next step
  if (c.nextStep) {
    h += '<div class="section"><div class="section-title">→ 下一步</div><div style="font-size:0.9em;line-height:1.7;white-space:pre-line">' + esc(c.nextStep) + '</div></div>';
  }

  if (!c.hasBrief && c.urgencyKey !== 'frozen') {
    h += '<div class="info-note">📝 暂无状态卡。运行 /okki 深度分析创建详细档案。</div>';
  }

  h += '</div>';
  h += '<div class="modal-footer"><button class="btn btn-primary">✏️ 起草回复</button><button class="btn">🔍 深度分析</button><button class="btn">✅ 标记已处理</button></div>';

  document.getElementById('modal').innerHTML = h;
  document.getElementById('overlay').classList.add('show');
}

function closeModal() {
  document.getElementById('overlay').classList.remove('show');
}

function esc(s) {
  if (typeof s !== 'string') return String(s);
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
</script>

</body>
</html>`;

  return html;
}

// ═══════════════════════════════════════════════
// Markdown 表格（兼容旧模式）
// ═══════════════════════════════════════════════

function renderMarkdown(cards) {
  const active = cards.filter(c => c.urgencyKey !== "frozen");
  const counts = {};
  for (const c of cards) counts[c.urgencyKey] = (counts[c.urgencyKey] || 0) + 1;

  let md = `# OKKI 客户看板\n\n`;
  md += `> ${TODAY} | 🔴需立即处理:${counts.red||0} 🟡需定时关注:${counts.yellow||0} ⚪正常:${counts.grey||0} ❄️冷冻:${counts.frozen||0}\n\n`;
  md += `| 客户 | 国家 | 等级 | 阶段 | 最后联系 | 驱动因子 | 下一步 |\n`;
  md += `|------|------|:---:|------|----------|----------|--------|\n`;

  let lastU = "";
  for (const u of ["red", "yellow", "grey"]) {
    for (const c of active) {
      if (c.urgencyKey !== u) continue;
      if (c.urgencyKey !== lastU) {
        lastU = c.urgencyKey;
        const label = URGENCY[u.toUpperCase()] ? URGENCY[u.toUpperCase()].label : u;
        md += `| **── ${label} ──** | | | | | | |\n`;
      }
      const factorNames = c.richDrivers.map(d => d.title.replace(/——.*$/, "")).join(" · ") || "—";
      const daysStr = c.daysSince !== null ? `${c.daysSince}天前` : "?";
      md += `| ${c.name} | ${c.countryCN} | ${c.tier} | ${c.stage} | ${daysStr} | ${factorNames} | ${(c.nextStep || "—").replace(/\n/g, " ")} |\n`;
    }
  }
  return md;
}

// ═══════════════════════════════════════════════
// 旧版 HTML 表格（--html 兼容）
// ═══════════════════════════════════════════════

function renderHTMLTable(cards) {
  const active = cards.filter(c => c.urgencyKey !== "frozen");

  let html = `<!DOCTYPE html>
<html lang="zh-CN">
<head><meta charset="UTF-8"><title>OKKI 客户看板 — ${TODAY}</title>
<style>
  body { font-family: -apple-system, sans-serif; margin: 20px; color: #333; }
  table { border-collapse: collapse; width: 100%; font-size: 0.9em; }
  th { background: #f5f5f5; padding: 10px 8px; text-align: left; border-bottom: 2px solid #ddd; }
  td { padding: 8px; border-bottom: 1px solid #eee; vertical-align: top; }
  .heat-red { color: #d32f2f; font-weight: bold; }
  .heat-yellow { color: #f57c00; }
  .heat-grey { color: #999; }
  .section-row td { background: #f0f0f0; font-weight: bold; padding: 6px 8px; font-size: 0.85em; }
</style></head><body>
<h1>OKKI 客户看板</h1><p>${TODAY}</p>
<table><thead><tr><th>客户</th><th>国家</th><th>等级</th><th>阶段</th><th>最后联系</th><th>驱动因子</th><th>下一步</th></tr></thead><tbody>`;

  let lastU = "";
  for (const c of active) {
    if (c.urgencyKey !== lastU) {
      lastU = c.urgencyKey;
      html += `<tr class="section-row"><td colspan="7">── ${URGENCY[c.urgencyKey.toUpperCase()]?.label || c.urgencyKey} ──</td></tr>\n`;
    }
    const cls = `heat-${c.urgencyKey}`;
    const factors = c.richDrivers.map(d => d.title).join(" · ") || "—";
    html += `<tr>
  <td>${esc(c.name)}</td><td>${c.countryCN}</td><td>${c.tier}</td><td>${c.stage}</td>
  <td>${c.daysSince !== null ? c.daysSince + "天前" : "?"}</td>
  <td>${esc(factors)}</td><td>${esc((c.nextStep || "—").replace(/\n/g, " "))}</td></tr>\n`;
  }

  html += `</tbody></table></body></html>`;
  return html;
}

function esc(s) {
  if (typeof s !== "string") return String(s);
  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

// ═══════════════════════════════════════════════
// main
// ═══════════════════════════════════════════════

function main() {
  const cards = buildCustomerCards();
  if (!cards) process.exit(1);

  const counts = {};
  for (const c of cards) counts[c.urgencyKey] = (counts[c.urgencyKey] || 0) + 1;

  let output;
  if (mdMode) {
    output = renderMarkdown(cards);
  } else if (htmlTableMode) {
    output = renderHTMLTable(cards);
  } else {
    output = renderMatrixHTML(cards);
  }

  const dest = outFile || (mdMode || htmlTableMode ? null : path.join(OUTPUT_DIR, "dashboard.html"));

  if (dest) {
    fs.writeFileSync(dest, output, "utf-8");
    console.log(`✅ 看板已生成: ${dest}`);
  } else {
    console.log(output);
  }

  console.error(`\n── OKKI 看板 ${TODAY} ──`);
  console.error(`🔴 需立即处理: ${counts.red || 0}人`);
  console.error(`🟡 需定时关注: ${counts.yellow || 0}人`);
  console.error(`⚪ 正常流转:   ${counts.grey || 0}人`);
  console.error(`❄️ 冷冻:       ${counts.frozen || 0}人`);
  console.error(`📊 总计:       ${cards.length}人`);
}

main();
