/** 从原版 dashboard HTML 提取数据，生成 Pico CSS + ECharts 升级版 */
const fs = require("fs");
const path = require("path");

const SRC = path.join(__dirname, "dashboard_2026-05-19.html");
const DST = path.join(__dirname, "dashboard_2026-05-19_v2.html");
const html = fs.readFileSync(SRC, "utf8");

// 提取 KPI 数字
const kpiMatch = html.match(/<div class="num">(\d+)<\/div>/g);
const kpiNums = kpiMatch ? kpiMatch.map(m => m.match(/\d+/)[0]) : [];
const [total, active3d, silent90, ballOurs, needConfirm, needAction] = kpiNums;

// 提取 MATRIX JSON
const matrixMatch = html.match(/window\.MATRIX\s*=\s*(\{.*?\});\s*(?:window\.KPI_DATA|function)/s);
if (!matrixMatch) { console.error("MATRIX not found"); process.exit(1); }
const matrix = JSON.parse(matrixMatch[1]);

// 提取 KPI_DATA JSON
const kpiDataMatch = html.match(/window\.KPI_DATA\s*=\s*(\{.*?\});\s*function/s);
let kpiData = {};
if (kpiDataMatch) {
  try { kpiData = JSON.parse(kpiDataMatch[1]); } catch(e) {}
}

const stages = ["需求探索","报价已发","谈判中","待付款","待发货","已发货/在途","已签收","售后","待返单"];
const grades = ["S","A","B","C","D"];

// 算矩阵汇总
const matrixCounts = {};
for (const stage of stages) {
  matrixCounts[stage] = {};
  for (const g of grades) {
    matrixCounts[stage][g] = (matrix[stage] && matrix[stage][g]) ? matrix[stage][g].length : 0;
  }
}

// 热力图数据
const heatmapData = [];
for (let si = 0; si < stages.length; si++) {
  for (let gi = 0; gi < grades.length; gi++) {
    const cnt = matrixCounts[stages[si]][grades[gi]];
    if (cnt > 0) heatmapData.push([gi, si, cnt]);
  }
}

const maxHeat = Math.max(1, ...Object.values(matrixCounts).flatMap(r => Object.values(r)));

// 构建矩阵表格行
const matrixRows = stages.map(stage => {
  const cells = grades.map(g => {
    const cnt = matrixCounts[stage][g];
    if (cnt === 0) return `<td class="empty">0</td>`;
    const opacity = Math.min(cnt * 0.03 + 0.08, 0.55).toFixed(3);
    return `<td class="cell" style="background:rgba(255,159,10,${opacity});" onclick="openMatrixModal('${stage}','${g}')">${cnt}</td>`;
  }).join("");
  return `<tr><th class="row-hd">${stage}</th>${cells}</tr>`;
}).join("\n");

const stagesJSON = JSON.stringify(stages);
const gradesJSON = JSON.stringify(grades);
const heatmapJSON = JSON.stringify(heatmapData);
const barDataJSON = JSON.stringify(stages.map(s => grades.reduce((sum, g) => sum + matrixCounts[s][g], 0)));

// 生成颜色渐变条数据...

