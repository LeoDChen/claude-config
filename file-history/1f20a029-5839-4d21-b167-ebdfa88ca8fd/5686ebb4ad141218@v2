<script>
var MATRIX = ${JSON.stringify(matrix)};
var KPI_DATA = ${JSON.stringify(kpiData)};

function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function gradeBadge(g) {
  return '<span class="grade-badge grade-'+g+'">'+esc(g)+'</span>';
}

function openMatrixModal(stage, grade) {
  var data = (MATRIX[stage] && MATRIX[stage][grade]) ? MATRIX[stage][grade] : [];
  document.getElementById("modal-title").innerHTML = esc(stage) + ' × ' + esc(grade) + '级 — ' + data.length + '人';
  var rows = '';
  for (var i=0; i<data.length; i++) {
    var c = data[i];
    var confIcon = c.cf === 'uncertain' ? ' ⚠️' : '';
    var reasonStr = c.rs ? '<br><small style="color:var(--pico-muted-color);">📋 '+esc(c.rs)+'</small>' : '';
    rows += '<tr><td style="white-space:nowrap;">'+gradeBadge(c.g)+'<strong>'+esc(c.n)+confIcon+'</strong></td><td style="text-align:center;white-space:nowrap;">'+esc(c.c)+' · '+c.d+'d</td><td>'+esc(c.st)+reasonStr+'</td><td><strong>'+esc(c.ac)+'</strong></td></tr>';
  }
  document.getElementById("modal-body").innerHTML =
    '<table><tr><th style="width:140px;">客户</th><th style="text-align:center;width:100px;">国家 · 静默</th><th>阶段 / 依据</th><th>行动方向</th></tr>'+rows+'</table>'+
    '<p style="margin-top:8px;font-size:0.72rem;color:var(--pico-muted-color);">⚠️=AI不确定 | ESC/点击遮罩关闭</p>';
  document.getElementById("modal-overlay").classList.add("show");
}

function openKpiModal(key) {
  var data = KPI_DATA[key] || [];
  document.getElementById("modal-title").innerHTML = esc(key) + ' — ' + data.length + '人';
  var rows = '';
  for (var i=0; i<data.length; i++) {
    var c = data[i];
    var confIcon = c.cf === 'uncertain' ? ' ⚠️' : '';
    rows += '<tr><td>'+gradeBadge(c.g)+'<strong>'+esc(c.n)+confIcon+'</strong></td><td style="text-align:center;">'+esc(c.c)+' · '+(c.d===999?'?':c.d+'d')+'</td><td>'+esc(c.st)+'</td><td><strong>'+esc(c.ac)+'</strong></td></tr>';
  }
  document.getElementById("modal-body").innerHTML =
    '<table><tr><th style="width:140px;">客户</th><th style="text-align:center;width:100px;">国家 · 静默</th><th>阶段</th><th>行动方向</th></tr>'+rows+'</table>'+
