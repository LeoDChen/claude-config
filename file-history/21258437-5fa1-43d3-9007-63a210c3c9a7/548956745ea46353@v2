    '订单执行中': { label: '订单执行中', byQuality: { S:'每周主动同步进度，拍照/视频，关键节点提前通知', A:'每周同步，关键节点通知', B:'关键节点通知（排产/发货）', C:'发货时通知', D:'发货时通知' }, defaultAction: '关键节点主动通知（排产/完成/发货）' },
    '已签收': { label: '已签收', byQuality: { S:'签收7天回访，同步新品+定制方案，争取复购', A:'签收7天回访，发新品目录', B:'签收7天回访，确认满意度', C:'签收后回访一次', D:'签收后回访一次' }, defaultAction: '确认收货满意，推动复购' },
    '售后': { label: '售后', byQuality: { S:'≤1h响应，主动提供补偿方案', A:'≤1h响应，24h内给方案', B:'24h响应', C:'24h内回复', D:'24h内回复' }, defaultAction: '快速响应，妥善处理' },
  };

  // 构建静默HTML
  const silenceHtml = silenceTiers.map(tier => {
    const items = silenceGroups[tier.label] || [];
    if (items.length === 0) return '';
    const itemsHtml = items.sort((a, b) => {
      const da = a.lastCustomerMsgDays === '-' ? 9999 : a.lastCustomerMsgDays;
      const db = b.lastCustomerMsgDays === '-' ? 9999 : b.lastCustomerMsgDays;
      return db - da;
    }).map(e => {
      const d = e.lastCustomerMsgDays === '-' ? '?' : e.lastCustomerMsgDays;
      return '<div style="display:flex;justify-content:space-between;padding:2px 0;font-size:11px;"><span>' + esc(e.name) + ' <span style="color:var(--text-secondary);">' + esc(e.country || '??') + '</span></span><span>' + d + '天</span></div>';
    }).join('');
    return '<div>' +
      '<div onclick="var d=this.nextElementSibling;d.style.display=d.style.display===\'block\'?\'none\':\'block\'" style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;border-bottom:1px solid var(--border);cursor:pointer;">' +
      '<span>● <strong style="color:' + tier.color + ';">' + tier.label + '</strong></span>' +
      '<strong style="font-size:16px;color:' + tier.color + ';">' + items.length + '</strong></div>' +
      '<div style="display:none;padding:8px 14px;background:rgba(' + (tier.color === '#27ae60' ? '39,174,96' : tier.color === '#3498db' ? '52,152,219' : tier.color === '#f39c12' ? '243,156,18' : tier.color === '#e67e22' ? '230,126,34' : '192,57,43') + ',0.08);border-bottom:1px solid var(--border);">' + itemsHtml + '</div></div>';
  }).filter(Boolean).join('');

  // 市场分布
  const coreMarkets = ['SD', 'EG', 'CD', 'ZM', 'CI', 'SA', 'AE'];
  const coreNames = { SD:'苏丹', EG:'埃及', CD:'刚果民主', ZM:'赞比亚', CI:'科特迪瓦', SA:'沙特', AE:'阿联酋' };
  const marketData = {};
  for (const mk of coreMarkets) marketData[mk] = { count: 0, sa: 0, action: 0 };
  for (const e of data) {
    const c = e.country || '';
    if (marketData[c] !== undefined) {
      marketData[c].count++;
      if (e.grade === 'S' || e.grade === 'A') marketData[c].sa++;
      if (e.stageLabel === '待回复' || e.questionUnanswered || e.stageLabel === 'PI已发') marketData[c].action++;
    }
  }
  const marketRows = coreMarkets.filter(mk => marketData[mk].count > 0).map(mk => {
    const md = marketData[mk];
    return '<tr><td style="padding:8px;border:1px solid var(--border);font-weight:600;">' + coreNames[mk] + '</td>' +
      '<td style="text-align:center;padding:8px;border:1px solid var(--border);">' + md.count + '</td>' +
      '<td style="text-align:center;padding:8px;border:1px solid var(--border);">' + md.sa + '</td>' +
      '<td style="text-align:center;padding:8px;border:1px solid var(--border);color:#c0392b;font-weight:bold;">' + md.action + '</td></tr>';
  }).join('');

  // 矩阵表格行
  const matrixRows = stageOrder.map(s => {
    const cells = gradeOrder.map(g => {
      const items = matrixData[s] ? (matrixData[s][g] || []) : [];
      const n = items.length;
      if (n === 0) return '<td style="text-align:center;padding:6px 8px;border:1px solid var(--border);color:var(--text-tertiary);">0</td>';
      let opacity = Math.min(0.5, 0.15 + n * 0.005);
      if (g === 'S') opacity = Math.min(0.5, 0.2 + n * 0.02);
      return '<td style="text-align:center;padding:6px 8px;border:1px solid var(--border);cursor:pointer;background:rgba(255,159,10,' + opacity + ');font-weight:600;" onclick="openModal(\'' + s + '\',\'' + g + '\')">' + n + '</td>';
    }).join('');
    return '<tr><td class="rl">' + s + '</td>' + cells + '</tr>';
  }).join('');

  // 构建 MATRIX JSON (简化版，只含展示所需)
  const matrixJson = {};
  for (const s of stageOrder) {
    matrixJson[s] = {};
    for (const g of gradeOrder) {
      matrixJson[s][g] = (matrixData[s][g] || []).map(e => ({
        n: e.name,
        c: e.country || '??',
        d: e.lastCustomerMsgDays === '-' ? 999 : e.lastCustomerMsgDays,
        s: e.questionUnanswered ? 'attention' : (e.lastCustomerMsgDays !== '-' && e.lastCustomerMsgDays > 14 ? 'watch' : 'normal')
      }));
    }
  }

  const html = '<!DOCTYPE html>\n<html lang="zh-CN">\n<head>\n<meta charset="utf-8">\n<title>OKKI 客户管道看板 — ' + today + '</title>\n' +
'<style>\n' +
'  :root { --bg-primary: #f5f5f7; --bg-secondary: #ffffff; --bg-tertiary: #e5e5e7; --border: #d1d1d6;\n' +
'    --text-primary: #1d1d1f; --text-secondary: #86868b; --text-tertiary: #aeaeb2;\n' +
'    --accent: #0071e3; --success: #34c759; --warning: #ff9f0a; --error: #ff3b30; }\n' +
'  @media (prefers-color-scheme: dark) {\n' +
'    :root { --bg-primary: #1d1d1f; --bg-secondary: #2d2d2f; --bg-tertiary: #3d3d3f;\n' +
'      --border: #424245; --text-primary: #f5f5f7; --text-secondary: #86868b;\n' +
'      --text-tertiary: #636366; --accent: #0a84ff; }\n' +
'  }\n' +
'  * { box-sizing: border-box; margin: 0; padding: 0; }\n' +
'  body { font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif;\n' +
'    background: var(--bg-primary); color: var(--text-primary); line-height: 1.5;\n' +
'    padding: 20px 24px; max-width: 1400px; margin: 0 auto; }\n' +
'  h1 { font-size: 1.3rem; margin-bottom: 4px; }\n' +
'  .subtitle { color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 20px; }\n' +
'  .kpi-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-bottom: 20px; }\n' +
'  .kpi { color: #fff; padding: 14px 12px; border-radius: 8px; text-align: center; }\n' +
'  .kpi .num { font-size: 28px; font-weight: 700; }\n' +
'  .kpi .lbl { font-size: 11px; opacity: 0.9; }\n' +
'  .card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-bottom: 16px; }\n' +
'  .card-hd { background: var(--bg-tertiary); padding: 10px 14px; font-weight: 600; font-size: 13px; border-bottom: 1px solid var(--border); }\n' +
'  .card-hd span { font-weight: normal; font-size: 11px; color: var(--text-secondary); }\n' +
'  table.mx { width: 100%; border-collapse: collapse; font-size: 12px; }\n' +
'  table.mx th { padding: 6px 8px; border: 1px solid var(--border); background: var(--bg-tertiary); font-weight: 600; }\n' +
'  table.mx td { border: 1px solid var(--border); }\n' +
'  table.mx td.rl { text-align: left; font-weight: 600; padding: 6px 8px; }\n' +
'  .flex { display: flex; gap: 16px; margin-bottom: 16px; }\n' +
'  .flex-1 { flex: 1; }\n' +
'  .flex-320 { flex: 0 0 340px; }\n' +
'  table.sub { width: 100%; border-collapse: collapse; font-size: 12px; }\n' +
'  table.sub th { padding: 8px; border: 1px solid var(--border); text-align: left; background: var(--bg-tertiary); font-weight: 600; }\n' +
'  table.sub td { padding: 8px; border: 1px solid var(--border); }\n' +
'  .trend-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid var(--border); }\n' +
'  .trend-row .det { font-size: 11px; color: var(--text-secondary); }\n' +
'  .footer { margin-top: 24px; padding: 14px; border-top: 1px solid var(--border); font-size: 11px; color: var(--text-secondary); text-align: center; }\n' +
'  .footer a { color: var(--accent); }\n' +
'  .modal-overlay { display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.45); z-index:9999; justify-content:center; align-items:center; }\n' +
'  .modal-overlay.show { display:flex; }\n' +
'  .modal-box { background:var(--bg-secondary); border-radius:10px; width:700px; max-width:92vw; max-height:75vh; overflow-y:auto; box-shadow:0 8px 30px rgba(0,0,0,0.25); }\n' +
'  @media (prefers-color-scheme: dark) { .modal-box { box-shadow:0 8px 30px rgba(0,0,0,0.6); } }\n' +
'  .modal-hd { display:flex; justify-content:space-between; align-items:center; padding:14px 18px; border-bottom:1px solid var(--border); font-weight:600; font-size:15px; position:sticky; top:0; background:var(--bg-secondary); border-radius:10px 10px 0 0; z-index:1; }\n' +
'  .modal-close { cursor:pointer; font-size:20px; color:var(--text-secondary); line-height:1; padding:0 4px; border:none; background:none; }\n' +
'  .modal-close:hover { color:var(--text-primary); }\n' +
'  .modal-body { padding:14px 18px; }\n' +
'  .modal-body table { width:100%; border-collapse:collapse; font-size:12px; }\n' +
'  .modal-body th { padding:6px 8px; border:1px solid var(--border); background:var(--bg-tertiary); text-align:left; font-weight:600; }\n' +
'  .modal-body td { padding:6px 8px; border:1px solid var(--border); }\n' +
'</style>\n</head>\n<body>\n\n' +
'<h1>OKKI 客户管道看板</h1>\n' +
'<div class="subtitle">生成时间：' + timeStr + ' | 数据源：s1_classification.json + chat_history | 全覆盖 ' + total + ' 客户</div>\n\n' +
'<div class="kpi-grid">\n' +
  kpiCards.map(c => '<div class="kpi" style="background:' + c.color + ';"><div class="num">' + c.num + '</div><div class="lbl">' + c.label + '</div></div>').join('\n') + '\n</div>\n\n' +
'<div class="card">\n  <div class="card-hd">客户双轴矩阵 <span>（生命周期 × 质量）— 点击格子展开客户名单 + 标准动作</span></div>\n' +
'  <div style="overflow-x:auto;">\n    <table class="mx">\n      <tr><th style="text-align:left;min-width:80px;">阶段 \\ 等级</th><th>S</th><th>A</th><th>B</th><th>C</th><th>D</th></tr>\n' +
'      ' + matrixRows + '\n    </table>\n  </div>\n' +
'  <div style="padding:6px 14px;font-size:10px;color:var(--text-secondary);">颜色越深=该格客户越多 | 点击数字弹出详情（标准动作 + 客户名单）</div>\n</div>\n\n' +
'<div class="flex">\n  <div class="flex-320 card">\n    <div class="card-hd">静默风险分级</div>\n    <div>\n    ' + silenceHtml + '\n    </div>\n  </div>\n' +
'  <div class="flex-1 card" style="align-self:flex-start;">\n    <div class="card-hd">本期变动（相较上次运行）</div>\n' +
'    <div style="padding:10px 14px;font-size:13px;">\n' +
'      <div class="trend-row"><span>📈 升级</span><strong style="color:#27ae60;">0人</strong><span class="det">-</span></div>\n' +
'      <div class="trend-row"><span>📉 降级</span><strong style="color:#e74c3c;">0人</strong><span class="det">-</span></div>\n' +
'      <div class="trend-row"><span>🆕 新进入</span><strong style="color:#3498db;">0人</strong><span class="det">-</span></div>\n' +
'      <div class="trend-row" style="border-bottom:none;"><span>⏸️ 流失</span><strong style="color:var(--text-secondary);">0人</strong><span class="det">-</span></div>\n' +
'    </div>\n  </div>\n</div>\n\n' +
'<div class="card">\n  <div class="card-hd">核心市场管道密度</div>\n' +
'  <table class="sub">\n    <tr><th>市场</th><th style="text-align:center;">客户数</th><th style="text-align:center;">S/A级</th><th style="text-align:center;">需行动</th></tr>\n    ' + marketRows + '\n  </table>\n</div>\n\n' +
'<div class="footer">管道看板 — 脚本自动生成，覆盖全部 ' + total + ' 客户 | 深度分析请新开对话 | 生成时间：' + timeStr + '</div>\n\n' +
'<div id="modal-overlay" class="modal-overlay" onclick="if(event.target===this)closeModal()">\n' +
'  <div class="modal-box"><div class="modal-hd"><span id="modal-title"></span><button class="modal-close" onclick="closeModal()">✕</button></div>\n' +
'    <div class="modal-body" id="modal-body"></div></div>\n</div>\n\n' +
'<script>\n' +
'window.MATRIX = ' + JSON.stringify(matrixJson) + ';\n' +
'window.ACTIONS = ' + JSON.stringify(actions) + ';\n' +
'function esc(s) { return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }\n' +
'function statusBadge(s) {\n' +
'  if (s === "attention") return \'<span style="background:#e67e22;color:#fff;padding:1px 6px;border-radius:3px;font-size:10px;">关注</span>\';\n' +
'  if (s === "watch") return \'<span style="background:#f39c12;color:#fff;padding:1px 6px;border-radius:3px;font-size:10px;">观察</span>\';\n' +
'  return ""; }\n' +
'function openModal(ls, q) {\n' +
'  var data = window.MATRIX[ls][q];\n' +
'  var action = window.ACTIONS[ls];\n' +
'  var actionText = action ? (action.byQuality[q] || action.defaultAction) : "";\n' +
'  document.getElementById("modal-title").innerHTML = esc(ls) + " × " + esc(q) + "级 — " + data.length + "人";\n' +
'  var rows = "";\n' +
'  for (var i = 0; i < data.length; i++) {\n' +
'    var c = data[i];\n' +
'    rows += "<tr><td style=\\"font-weight:600;\\">" + esc(c.n) + "</td><td>" + esc(c.c) + "</td><td style=\\"text-align:center;\\">" + c.d + "d</td><td style=\\"text-align:center;\\">" + statusBadge(c.s) + "</td></tr>";\n' +
'  }\n' +
'  document.getElementById("modal-body").innerHTML =\n' +
'    \'<div style="padding:8px 12px;margin-bottom:12px;background:var(--bg-tertiary);border-radius:6px;color:var(--accent);font-size:12px;">📋 标准动作：\' + esc(actionText) + \'</div>\' +\n' +
'    \'<div style="max-height:50vh;overflow-y:auto;"><table><tr><th>客户</th><th style="text-align:center;">国家</th><th style="text-align:center;">静默</th><th style="text-align:center;">状态</th></tr>\' + rows + \'</table></div>\' +\n' +
'    \'<div style="margin-top:8px;font-size:10px;color:var(--text-tertiary);">💡 点击遮罩 / ✕ 按钮 / ESC 关闭</div>\';\n' +
'  document.getElementById("modal-overlay").classList.add("show"); }\n' +
'function closeModal() { document.getElementById("modal-overlay").classList.remove("show"); }\n' +
'document.addEventListener("keydown", function(e) { if (e.key === "Escape") closeModal(); });\n' +
'</script>\n</body>\n</html>';

  const outPath = path.join(__dirname, '..', 'output', 'dashboard_' + today + '.html');
  fs.writeFileSync(outPath, html, 'utf-8');
  console.log('看板 → ' + outPath);

  // 同时保存增强后的全量JSON
  fs.writeFileSync(path.join(__dirname, '..', 'data', 's1_enhanced_full.json'), JSON.stringify(data, null, 2));
  console.log('全量数据 → data/s1_enhanced_full.json (' + data.length + '条)');
}
