/**
 * OKKI 每日客户分析一键流水线
 *
 * 用法：
 *   node scripts/daily_pipeline.js           完整流程
 *   node scripts/daily_pipeline.js --no-ai   跳过AI话术
 *   node scripts/daily_pipeline.js --p0-only 只看P0客户
 *
 * 输入：
 *   data/tm_conversations_latest.json — 全量466客户元数据（由sync_okki.js产出）
 *   data/s1_enhanced.json          — 44活跃客户的增强特征（由enhanced_classify.js产出）
 * 输出：
 *   output/daily_YYYY-MM-DD.xlsx   — Excel看板
 *   output/actions_YYYY-MM-DD.md   — 行动清单
 */

const fs = require('fs');
