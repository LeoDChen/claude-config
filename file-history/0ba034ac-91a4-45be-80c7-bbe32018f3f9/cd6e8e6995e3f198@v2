        { label: '优势', planA: '简单', planB: '给客户新的关注理由，不是催单' },
        { label: '风险', planA: '客户无视', planB: '需要新素材支撑' },
      ];
      analysis.step4 = `Hi ${c.name.split(' ')[0]}，好久没联系！最近我们产线新出了一批${isFrench ? 'vêtements bébé' : '婴童款式'}，性价比很高。另外我刚好整理了我们用的预洗精梳棉和市面普通棉的对比图——一眼就能看出差别。你现在还在看这个品类吗？`;
      analysis.step4Lines = [
        `钩子: 面料对比图 + 新品实拍（二选一邀请）`,
      ];
      analysis.step5 = [
        '✅ 客户回复 → 根据回复内容定向推荐',
        '⚠️ 客户说在做别的 → 了解新方向，看是否有切入点',
        '⏰ 7天后仍未回 → 归入P3休眠池，等下一轮批量激活',
      ];
    } else if (hasComplaint) {
      analysis.step2 = ['售后/质量问题——客户已表达不满但在沟通', '信任在崩塌边缘，处理不当会失去客户'];
      analysis.step3 = [
        { label: '策略', planA: '解释/推卸责任', planB: '诚实面对+快速响应+给出具体方案' },
        { label: '优势', planA: '短期可能省成本', planB: '保住长期客户关系，B2B复购才是利润' },
        { label: '风险', planA: '丢失客户+负面口碑', planB: '可能需要承担赔偿/重做成本' },
      ];
      analysis.step4 = `谢谢你愿意沟通。品质问题我们非常重视——请具体描述一下问题（最好有照片），我直接呈报给生产主管和老板。如果是我们的问题，全额退款或重做。这不会影响我们未来的合作。`;
      analysis.step4Lines = [
        `关键: 先认错，不推卸，给具体行动方案`,
        `底线: 不虚构原因，不确定的事说"我先查"`,
      ];
      analysis.step5 = [
        '✅ 客户接受方案 → 快速执行（退款/重做）+ 后续跟进',
        '⚠️ 客户要求更多 → 在合理范围内满足，超出范围的诚实说明',
        '⏰ 客户沉默 → 2天后追问一次，再沉默则暂停',
      ];
    } else if (daysAgo <= 3) {
      analysis.step2 = ['近期互动中，需温和跟进', '客户可能在正常决策周期中'];
      analysis.step3 = [
        { label: '策略', planA: '等待客户主动回复', planB: '发一个有价值的钩子（不是催单）' },
        { label: '优势', planA: '不打扰', planB: '保持存在感+提供价值' },
        { label: '风险', planA: '客户可能忘了我们', planB: '频率过高可能反感' },
      ];
      analysis.step4 = `Hi，上次聊的${isFrench ? 'produit' : '产品'}你还在考虑吗？刚好我整理了一个对比——我们用的预洗精梳棉和市面普通棉的区别，10秒就能看出差别。不影响你决策，纯粹供参考。`;
      analysis.step4Lines = [`钩子: 面料对比图 + 二选一邀请`];
      analysis.step5 = [
        '✅ 客户回复 → 根据需求推进',
        '⏰ 3天后未回 → 用帮宝适奥运钩子激活',
      ];
    } else {
      analysis.step2 = ['客户沉默中，需重新建立联系', '可能原因: 比价/预算问题/找别家/季节性波动'];
      analysis.step3 = [
        { label: '策略', planA: '发跟进消息', planB: '品质钩子+新品/季节款推荐' },
      ];
      analysis.step4 = `Hi ${c.name.split(' ')[0]}，最近出了几款新婴童款式，性价比很高。我们去年给帮宝适奥运款做吸汗巾的——品质你可以放心。需要我发几张新品实拍给你看看吗？`;
      analysis.step5 = ['✅ 回复 → 推进', '⏰ 不回 → 归入休眠池'];
    }

    analyses.push(analysis);
  }

  return analyses;
}

function getP1Action(c) {
  const msg = (c.latestMessageContent || '').toLowerCase();
  if (/sample|样品/.test(msg)) return '安排寄样 + 品质背书';
  if (/price|cost|报价|how much/.test(msg)) return '补发报价 + 差异化话术';
  if (/ship|delivery|海运|快递/.test(msg)) return '确认物流方式 + 时效说明';
  if (/payment|pay|deposit/.test(msg)) return '催款 + 发货时间表';
  if (/complaint|return|refund/i.test(msg)) return '优先处理售后';
  return '温和跟进 + 品质钩子';
}

