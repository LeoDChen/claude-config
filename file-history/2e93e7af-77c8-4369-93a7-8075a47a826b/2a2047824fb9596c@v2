<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OKKI 看板 — 阶段主轴</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; padding: 24px; color: #333; }
  h1 { font-size: 1.3em; margin-bottom: 4px; }
  .subtitle { color: #999; font-size: 0.82em; margin-bottom: 24px; }

  .pipeline { display: flex; flex-direction: column; gap: 0; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.06); }

  .stage-group { border-bottom: 1px solid #f0f0f0; }
  .stage-group:last-child { border-bottom: none; }

  .stage-header { display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: #fafafa; border-bottom: 1px solid #eee; cursor: pointer; user-select: none; }
  .stage-header:hover { background: #f5f5f5; }
  .stage-icon { font-size: 1.3em; width: 28px; text-align: center; }
  .stage-name { font-weight: 600; font-size: 0.95em; min-width: 100px; }
  .stage-count { font-size: 0.78em; color: #999; margin-left: 4px; }
  .stage-bar { flex: 1; height: 4px; background: #e0e0e0; border-radius: 2px; }
  .stage-bar-fill { height: 100%; border-radius: 2px; }
  .bar-red { background: #ef5350; }
  .bar-yellow { background: #ffa726; }
  .bar-grey { background: #e0e0e0; }

  .customer-row { display: grid; grid-template-columns: 28px 110px 55px 1fr 140px; gap: 8px; align-items: center; padding: 10px 16px 10px 16px; border-bottom: 1px solid #f8f8f8; font-size: 0.88em; }
  .customer-row:last-child { border-bottom: none; }
  .customer-row:hover { background: #fafbfc; }

  .driver-dot { width: 10px; height: 10px; border-radius: 50%; justify-self: center; }
  .dot-red { background: #d32f2f; }
  .dot-yellow { background: #f57c00; }
  .dot-none { background: #e0e0e0; }

  .cust-name { font-weight: 500; }
  .cust-country { color: #888; font-size: 0.85em; }

  .driver-tags { display: flex; gap: 4px; flex-wrap: wrap; }
  .driver-tag { display: inline-block; padding: 2px 7px; border-radius: 3px; font-size: 0.75em; white-space: nowrap; }
  .tag-red { background: #ffebee; color: #c62828; border: 1px solid #ffcdd2; }
  .tag-yellow { background: #fff8e1; color: #e65100; border: 1px solid #ffecb3; }

  .cust-action { color: #555; font-size: 0.85em; max-width: 200px; }

  .empty-stage { padding: 10px 16px; color: #bbb; font-size: 0.82em; font-style: italic; }

  .legend { display: flex; gap: 20px; margin-bottom: 16px; font-size: 0.8em; color: #888; }
  .legend-item { display: flex; align-items: center; gap: 6px; }

  .summary-bar { margin-bottom: 16px; padding: 12px 16px; background: #fff; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.06); display: flex; gap: 24px; font-size: 0.85em; }
</style>
</head>
<body>

<h1>OKKI 客户看板</h1>
<p class="subtitle">按客户生命周期排列 · 2026-05-16 更新</p>

<div class="legend">
  <div class="legend-item"><span class="driver-dot dot-red" style="display:inline-block"></span> 需立即处理</div>
  <div class="legend-item"><span class="driver-dot dot-yellow" style="display:inline-block"></span> 需定时关注</div>
  <div class="legend-item"><span class="driver-dot dot-none" style="display:inline-block"></span> 无待办 / 冷冻</div>
</div>

<div class="summary-bar">
  <span>总客户: <strong>40</strong></span>
  <span>🔴 待处理: <strong>5</strong></span>
  <span>🟡 该关注: <strong>12</strong></span>
  <span>⚪ 冷冻: <strong>23</strong></span>
</div>

<div class="pipeline">

  <!-- 需求探索 -->
  <div class="stage-group">
    <div class="stage-header">
      <span class="stage-icon">🔍</span>
      <span class="stage-name">需求探索</span>
      <span class="stage-count">12人</span>
      <div class="stage-bar"><div class="stage-bar-fill bar-red" style="width:20%"></div></div>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-red"></span>
      <span class="cust-name">Inderpreet kaur</span>
      <span class="cust-country">美国</span>
      <span class="driver-tags"><span class="driver-tag tag-red">🔴 未回复</span><span class="driver-tag tag-yellow">🟡 该追问</span></span>
      <span class="cust-action">确认面料花型，推动样品单</span>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-yellow"></span>
      <span class="cust-name">Clara ElAssaad</span>
      <span class="cust-country">法国</span>
      <span class="driver-tags"><span class="driver-tag tag-yellow">🟡 该追问</span></span>
      <span class="cust-action">报价7天未回，追问需求</span>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-none"></span>
      <span class="cust-name">Aboulaye Rabiatou</span>
      <span class="cust-country">科特迪瓦</span>
      <span class="driver-tags"></span>
      <span class="cust-action">等待客户进一步沟通</span>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-none"></span>
      <span class="cust-name">Marcos Kuyu</span>
      <span class="cust-country">美国</span>
      <span class="driver-tags"></span>
      <span class="cust-action">确认数量和地址后报价</span>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-none"></span>
      <span class="cust-name">Tahar benmohamed</span>
      <span class="cust-country">加拿大</span>
      <span class="driver-tags"></span>
      <span class="cust-action">区分现货/定制需求</span>
    </div>
    <div style="padding:6px 16px;font-size:0.78em;color:#aaa;">+ 7 人</div>
  </div>

  <!-- 报价已发 -->
  <div class="stage-group">
    <div class="stage-header">
      <span class="stage-icon">💰</span>
      <span class="stage-name">报价已发</span>
      <span class="stage-count">8人</span>
      <div class="stage-bar"><div class="stage-bar-fill bar-yellow" style="width:50%"></div></div>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-red"></span>
      <span class="cust-name">jonathan aston</span>
      <span class="cust-country">加纳</span>
      <span class="driver-tags"><span class="driver-tag tag-red">🔴 待发货</span></span>
      <span class="cust-action">客已付，货还没出，安排发货</span>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-yellow"></span>
      <span class="cust-name">arshavin amoah</span>
      <span class="cust-country">加纳</span>
      <span class="driver-tags"><span class="driver-tag tag-yellow">🟡 该追问</span></span>
      <span class="cust-action">$15.50/3件，11天没回复</span>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-yellow"></span>
      <span class="cust-name">Hakim Ezat</span>
      <span class="cust-country">沙特</span>
      <span class="driver-tags"><span class="driver-tag tag-yellow">🟡 该追问</span></span>
      <span class="cust-action">$3.68×500pcs，11天沉默</span>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-yellow"></span>
      <span class="cust-name">Keinjol Tata</span>
      <span class="cust-country">印度</span>
      <span class="driver-tags"><span class="driver-tag tag-yellow">🟡 待确认DDP</span></span>
      <span class="cust-action">DDP运费$365待确认</span>
    </div>
    <div style="padding:6px 16px;font-size:0.78em;color:#aaa;">+ 4 人</div>
  </div>

  <!-- 样品阶段 -->
  <div class="stage-group">
    <div class="stage-header">
      <span class="stage-icon">🧪</span>
      <span class="stage-name">样品阶段</span>
      <span class="stage-count">3人</span>
      <div class="stage-bar"><div class="stage-bar-fill bar-yellow" style="width:30%"></div></div>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-yellow"></span>
      <span class="cust-name">Aka-Mwau Esme</span>
      <span class="cust-country">赞比亚</span>
      <span class="driver-tags"><span class="driver-tag tag-yellow">🟡 该追问</span></span>
      <span class="cust-action">样品后14天没反馈，追问</span>
    </div>
    <div style="padding:6px 16px;font-size:0.78em;color:#aaa;">+ 2 人</div>
  </div>

  <!-- 谈判中 -->
  <div class="stage-group">
    <div class="stage-header">
      <span class="stage-icon">🤝</span>
      <span class="stage-name">谈判中</span>
      <span class="stage-count">2人</span>
      <div class="stage-bar"><div class="stage-bar-fill bar-red" style="width:50%"></div></div>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-red"></span>
      <span class="cust-name">Angela O</span>
      <span class="cust-country">美国</span>
      <span class="driver-tags"><span class="driver-tag tag-red">🔴 未回复</span></span>
      <span class="cust-action">PI已做等付，3天没回</span>
    </div>
    <div style="padding:6px 16px;font-size:0.78em;color:#aaa;">+ 1 人</div>
  </div>

  <!-- 待付款 -->
  <div class="stage-group">
    <div class="stage-header">
      <span class="stage-icon">💳</span>
      <span class="stage-name">待付款</span>
      <span class="stage-count">4人</span>
      <div class="stage-bar"><div class="stage-bar-fill bar-red" style="width:60%"></div></div>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-red"></span>
      <span class="cust-name">Nassir A</span>
      <span class="cust-country">苏丹</span>
      <span class="driver-tags"><span class="driver-tag tag-red">🔴 承诺未兑现</span><span class="driver-tag tag-yellow">🟡 到港提醒</span></span>
      <span class="cust-action">先确认库存 → 再通知5/18到港</span>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-yellow"></span>
      <span class="cust-name">Sara Dibes</span>
      <span class="cust-country">黎巴嫩</span>
      <span class="driver-tags"><span class="driver-tag tag-yellow">🟡 该追问</span></span>
      <span class="cust-action">PI已发12天已读不回</span>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-none"></span>
      <span class="cust-name">ali Amjid</span>
      <span class="cust-country">南非</span>
      <span class="driver-tags"></span>
      <span class="cust-action">等待客户确认付款</span>
    </div>
    <div style="padding:6px 16px;font-size:0.78em;color:#aaa;">+ 1 人</div>
  </div>

  <!-- 待发货 -->
  <div class="stage-group">
    <div class="stage-header">
      <span class="stage-icon">📦</span>
      <span class="stage-name">待发货</span>
      <span class="stage-count">5人</span>
      <div class="stage-bar"><div class="stage-bar-fill bar-yellow" style="width:40%"></div></div>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-yellow"></span>
      <span class="cust-name">Christabel Kanunsha</span>
      <span class="cust-country">赞比亚</span>
      <span class="driver-tags"><span class="driver-tag tag-yellow">🟡 该更新进度</span></span>
      <span class="cust-action">付款后5天没更新备货情况</span>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-none"></span>
      <span class="cust-name">sarah alnajar</span>
      <span class="cust-country">伊拉克</span>
      <span class="driver-tags"></span>
      <span class="cust-action">生产中，预计下周出货</span>
    </div>
    <div style="padding:6px 16px;font-size:0.78em;color:#aaa;">+ 3 人</div>
  </div>

  <!-- 已发货/在途 -->
  <div class="stage-group">
    <div class="stage-header">
      <span class="stage-icon">🚢</span>
      <span class="stage-name">已发货 / 在途</span>
      <span class="stage-count">4人</span>
      <div class="stage-bar"><div class="stage-bar-fill bar-yellow" style="width:30%"></div></div>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-yellow"></span>
      <span class="cust-name">Aloh Voma</span>
      <span class="cust-country">美国</span>
      <span class="driver-tags"><span class="driver-tag tag-yellow">🟡 物流跟踪</span></span>
      <span class="cust-action">海运中，跟踪到港时间</span>
    </div>
    <div style="padding:6px 16px;font-size:0.78em;color:#aaa;">+ 3 人</div>
  </div>

  <!-- 已签收 -->
  <div class="stage-group">
    <div class="stage-header">
      <span class="stage-icon">✅</span>
      <span class="stage-name">已签收</span>
      <span class="stage-count">3人</span>
      <div class="stage-bar"><div class="stage-bar-fill bar-yellow" style="width:30%"></div></div>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-yellow"></span>
      <span class="cust-name">WELE Mounia</span>
      <span class="cust-country">多哥</span>
      <span class="driver-tags"><span class="driver-tag tag-yellow">🟡 该回访</span></span>
      <span class="cust-action">签收8天，问销售和复购</span>
    </div>
    <div style="padding:6px 16px;font-size:0.78em;color:#aaa;">+ 2 人</div>
  </div>

  <!-- 已成交 -->
  <div class="stage-group">
    <div class="stage-header">
      <span class="stage-icon">⭐</span>
      <span class="stage-name">已成交</span>
      <span class="stage-count">2人</span>
      <div class="stage-bar"><div class="stage-bar-fill bar-grey" style="width:0%"></div></div>
    </div>
    <div class="customer-row">
      <span class="driver-dot dot-none"></span>
      <span class="cust-name">Ernestina Afriyie</span>
      <span class="cust-country">加纳</span>
      <span class="driver-tags"></span>
      <span class="cust-action">老客户，下次周期回访6/1</span>
    </div>
    <div style="padding:6px 16px;font-size:0.78em;color:#aaa;">+ 1 人</div>
  </div>

  <!-- 冷冻 -->
  <div class="stage-group">
    <div class="stage-header" style="opacity:0.5">
      <span class="stage-icon">❄️</span>
      <span class="stage-name">冷冻（>90天无互动）</span>
      <span class="stage-count">23人</span>
      <div class="stage-bar"><div class="stage-bar-fill bar-grey" style="width:0%"></div></div>
    </div>
    <div class="customer-row" style="opacity:0.5">
      <span class="driver-dot dot-none"></span>
      <span class="cust-name">MENTZEKO Mathi</span>
      <span class="cust-country">喀麦隆</span>
      <span class="driver-tags"></span>
      <span class="cust-action">冷层维护，等客户复活</span>
    </div>
    <div style="padding:6px 16px;font-size:0.78em;color:#aaa;">+ 22 人（折叠）</div>
  </div>

</div>

</body>
</html>
