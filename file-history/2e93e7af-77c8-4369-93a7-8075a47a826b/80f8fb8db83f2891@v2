<!DOCTYPE html><html lang="zh"><head><meta charset="UTF-8"><title>Test</title>
<style>
body{font-family:sans-serif;padding:40px;}
.chip{cursor:pointer;padding:6px 14px;border-radius:14px;background:#ffebee;border:1px solid #ffcdd2;display:inline-block;margin:4px;}
.chip:hover{background:#ffcdd2;}
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:999;justify-content:center;align-items:center;}
.overlay.on{display:flex;}
.modal{background:#fff;padding:30px;border-radius:12px;max-width:500px;box-shadow:0 10px 40px rgba(0,0,0,.2);}
.btn{background:#1976d2;color:#fff;border:none;padding:8px 20px;border-radius:6px;cursor:pointer;margin-top:12px;}
</style></head><body>
<h2>点击测试</h2>
<span class="chip" onclick="openModal('jonathan')">jonathan aston</span>
<span class="chip" onclick="openModal('inderpreet')">Inderpreet kaur</span>
<div class="overlay" id="ov" onclick="if(event.target===this)closeModal()">
<div class="modal" id="md"></div></div>
<script>
function openModal(name){document.getElementById('md').innerHTML='<h3>'+name+'</h3><p>弹窗成功</p><button class=btn onclick=closeModal()>关闭</button>';document.getElementById('ov').classList.add('on');}
function closeModal(){document.getElementById('ov').classList.remove('on');}
</script></body></html>
