$newPath = 'D:\下载'

# Fix both registry keys
$keys = @(
    'HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\User Shell Folders',
    'HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Shell Folders'
)

$guids = @(
    '{374DE290-123F-4565-9164-39C4925E467B}',  # Downloads
    '{7D83EE9B-2244-4E70-B1F5-5393042AF1E4}'   # Local Downloads
)

foreach ($key in $keys) {
    foreach ($guid in $guids) {
        $current = (Get-ItemProperty -Path $key -Name $guid -ErrorAction SilentlyContinue).$guid
        if ($current) {
            Write-Host "[$key] $guid : $current -> $newPath"
            Set-ItemProperty -Path $key -Name $guid -Value $newPath
        } else {
            Write-Host "[$key] $guid : NOT FOUND (skip)"
        }
    }
}

Write-Host "`nDone. Restarting Explorer..."
Stop-Process -Name explorer -Force
Start-Sleep -Seconds 1
Start-Process explorer.exe
Write-Host "Explorer restarted."
