// ========== 工具函数 ==========
function headerCell(text, width, color = '1a5276') {
  return new TableCell({
    width: { size: width, type: WidthType.PERCENTAGE },
    shading: { type: ShadingType.SOLID, color },
    children: [new Paragraph({ children: [new TextRun({ text, bold: true, color: 'FFFFFF', size: 20, font: 'Microsoft YaHei' })], spacing: { before: 30, after: 30 } })],
  });
}

function cell(text, width, opts = {}) {
  return new TableCell({
    width: { size: width, type: WidthType.PERCENTAGE },
    children: [new Paragraph({ children: [new TextRun({ text: String(text), size: 19, font: 'Microsoft YaHei', ...opts })], spacing: { before: 25, after: 25 } })],
  });
}

function redCell(text, width) {
  return cell(`🔴 ${text}`, width, { color: 'c0392b', bold: true });
}

function warnCell(text, width) {
  return cell(`⚠️ ${text}`, width, { color: 'e67e22' });
}

function heading(text, level) {
  const sizes = { 1: 32, 2: 26, 3: 22 };
  return new Paragraph({ heading: level, children: [new TextRun({ text, bold: true, font: 'Microsoft YaHei', size: sizes[level] || 22 })], spacing: { before: 200, after: 100 } });
}

function para(text, opts = {}) {
  return new Paragraph({ children: [new TextRun({ text, size: 21, font: 'Microsoft YaHei', ...opts })], spacing: { before: 60, after: 60 } });
}

function redPara(text) {
  return para(text, { color: 'c0392b', bold: true });
}

function makeTable(headers, rows, colWidths) {
  const hdrRow = new TableRow({ children: headers.map((h, i) => headerCell(h, colWidths[i])) });
  const dataRows = rows.map(row => new TableRow({ children: row.map((c, i) => {
    if (typeof c === 'object' && c._isRed) return redCell(c.text, colWidths[i]);
    if (typeof c === 'object' && c._isWarn) return warnCell(c.text, colWidths[i]);
    return cell(c, colWidths[i]);
  }) }));
  return new Table({ width: { size: 100, type: WidthType.PERCENTAGE }, rows: [hdrRow, ...dataRows] });
}

function red(text) { return { text, _isRed: true }; }
function warn(text) { return { text, _isWarn: true }; }

