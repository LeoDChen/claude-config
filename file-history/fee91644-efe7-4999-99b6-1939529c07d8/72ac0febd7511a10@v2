const fs = require('fs');
const buf = fs.readFileSync('C:/Users/Administrator/Desktop/PI_Dinmg_2026-04-27.pdf');
const text = buf.toString('latin1');

// Extract text from PDF content streams
const matches = text.match(/\(([^)]{2,150})\)/g) || [];
const unique = [...new Set(matches)].slice(0, 50);
unique.forEach(m => {
  const inner = m.substring(1, m.length - 1);
  const decoded = inner.replace(/\\(.)/g, '$1');
  if (decoded.length > 1) console.log(decoded);
});

// Check structure
console.log('\n--- FILE INFO ---');
console.log('Size:', buf.length);
console.log('Images:', (text.match(/\/Image/g) || []).length);
console.log('Font calls:', (text.match(/\/F\d+/g) || []).length);
console.log('/Type /Page count:', (text.match(/\/Type\s*\/Page/g) || []).length);
