const ExcelJS = require("exceljs");
const path = require("path");

const BASE = "C:/Users/Administrator/Desktop";

// ═══ Apple 风格常量 ═══
const C = {
  title: { name: "Calibri", size: 20, bold: false, color: { argb: "FF1D1D1F" } },
  subtitle: { name: "Calibri", size: 10, color: { argb: "FF86868B" } },
  section: { name: "Calibri", size: 13, bold: true, color: { argb: "FF1D1D1F" } },
  hdr: { name: "Calibri", size: 9, bold: true, color: { argb: "FF636366" } },
  body: { name: "Calibri", size: 10, color: { argb: "FF1D1D1F" } },
  bodyBold: { name: "Calibri", size: 10, bold: true, color: { argb: "FF1D1D1F" } },
  summary: { name: "Calibri", size: 11, bold: true, color: { argb: "FF1D1D1F" } },
  grandTotal: { name: "Calibri", size: 13, bold: true, color: { argb: "FF1D1D1F" } },
  note: { name: "Calibri", size: 8.5, italic: true, color: { argb: "FFAEAEB2" } },

  white: { type: "pattern", pattern: "solid", fgColor: { argb: "FFFFFFFF" } },
  alt: { type: "pattern", pattern: "solid", fgColor: { argb: "FFF5F5F7" } },
  headerBg: { type: "pattern", pattern: "solid", fgColor: { argb: "FFFAFAFA" } },
  summaryBg: { type: "pattern", pattern: "solid", fgColor: { argb: "FFF5F5F7" } },

  topBorder: { top: { style: "thin", color: { argb: "FFD1D1D6" } } },
  bottomThin: { bottom: { style: "thin", color: { argb: "FFE5E5EA" } } },
  bottomMid: { bottom: { style: "thin", color: { argb: "FFC7C7CC" } } },

  L: { horizontal: "left", vertical: "middle", wrapText: true },
  CC: { horizontal: "center", vertical: "middle", wrapText: true },
  R: { horizontal: "right", vertical: "middle" },
};

// ═══ 工具函数 ═══
function sc(ws, r, c, value, font, fill, align, border) {
  const cell = ws.getCell(r, c);
  cell.value = value;
  if (font) cell.font = font;
  if (fill) cell.fill = fill;
  if (align) cell.alignment = align;
  if (border) cell.border = border;
  return cell;
}

function sRow(ws, r, values, font, fill, align, border) {
  values.forEach((v, i) => sc(ws, r, i + 1, v, font, fill, align, border));
}

async function main() {
  const wb = new ExcelJS.Workbook();
  const ws = wb.addWorksheet("Quotation");

  ws.getColumn(1).width = 5;   // No.
  ws.getColumn(2).width = 17;  // Product Name
  ws.getColumn(3).width = 24;  // Photo
  ws.getColumn(4).width = 10;  // Size
  ws.getColumn(5).width = 7;   // Qty
  ws.getColumn(6).width = 13;  // Unit Price
  ws.getColumn(7).width = 13;  // Amount

  let row = 1;
  let seq = 0;

  // ═══════════ HEADER ═══════════
  ws.mergeCells(row, 1, row, 7);
  sc(ws, row, 1, "Quotation", C.title, C.white, C.CC, {});
  ws.getRow(row).height = 44;
  row++;

  ws.mergeCells(row, 1, row, 7);
  sc(ws, row, 1, "Baby & Kids Garments — 50 Pcs Mixed Order  ·  DDP Air Freight", C.subtitle, C.white, C.CC, {});
  ws.getRow(row).height = 20;
  row += 2;

  // ═══════════ SECTION HEADER ═══════════
  function addSection(title) {
    ws.mergeCells(row, 1, row, 7);
    sc(ws, row, 1, title, C.section, C.white, C.L, C.bottomMid);
    for (let c = 2; c <= 7; c++) ws.getCell(row, c).border = C.bottomMid;
    ws.getRow(row).height = 32;
    row++;
  }

  function addTableHeader() {
    sRow(ws, row, ["No.", "Product", "Photo", "Size", "Qty", "Unit Price", "Amount"], C.hdr, C.headerBg, C.CC, C.bottomMid);
    ws.getRow(row).height = 22;
    row++;
  }

  // ═══════════ 图片嵌入 ═══════════
  async function embedImage(ws, r, c, imgPath, imgSize) {
    // imgSize: { w, h } in pixels
    try {
      const ext = path.extname(imgPath).slice(1);
      const imgId = wb.addImage({ filename: imgPath, extension: ext });
      ws.addImage(imgId, {
        tl: { col: c - 1 + 0.12, row: r - 1 + 0.1 },
        ext: { width: imgSize.w, height: imgSize.h },
      });
    } catch (e) {
      ws.getCell(r, c).value = "[img]";
    }
  }

  // ═══════════ 单行产品 ═══════════
  async function singleProduct(imgPath, productName, sz, qty, unitPrice, isAlt) {
    seq++;
    const r = row;
    const rh = 125; // 行高足够图片不扁
    ws.getRow(r).height = rh;

    const amount = +(qty * unitPrice).toFixed(2);
    const bg = isAlt ? C.alt : C.white;
    const bdr = C.bottomThin;

    sc(ws, r, 1, seq, C.body, bg, C.CC, bdr);
    sc(ws, r, 2, productName, C.body, bg, C.L, bdr);
    sc(ws, r, 3, "", C.body, bg, C.CC, bdr);
    sc(ws, r, 4, sz, C.body, bg, C.CC, bdr);
    sc(ws, r, 5, qty, C.body, bg, C.CC, bdr);
    sc(ws, r, 6, unitPrice, C.body, bg, C.R, bdr);
    ws.getCell(r, 6).numFmt = "$#,##0.00";
    sc(ws, r, 7, amount, C.body, bg, C.R, bdr);
    ws.getCell(r, 7).numFmt = "$#,##0.00";

    if (imgPath) await embedImage(ws, r, 3, imgPath, { w: 140, h: 108 });
    row++;
  }

  // ═══════════ 双行合并产品（15M-2Y） ═══════════
  async function mergedProduct(imgPath, productName, sz1, q1, sz2, q2, unitPrice, isAlt) {
    seq++;
    const r1 = row;
    const r2 = row + 1;
    const eachRh = 65; // 两行共130
    ws.getRow(r1).height = eachRh;
    ws.getRow(r2).height = eachRh;

    const bg = isAlt ? C.alt : C.white;
    const totalQty = q1 + q2;
    const amount = +(totalQty * unitPrice).toFixed(2);

    sc(ws, r1, 1, seq, C.body, bg, C.CC, C.bottomThin);
    sc(ws, r1, 2, productName, C.body, bg, C.L, C.bottomThin);
    sc(ws, r1, 3, "", C.body, bg, C.CC, C.bottomThin);
    sc(ws, r1, 4, sz1, C.body, bg, C.CC, C.bottomThin);
    sc(ws, r1, 5, q1, C.body, bg, C.CC, C.bottomThin);
    sc(ws, r1, 6, unitPrice, C.body, bg, C.R, C.bottomThin);
    ws.getCell(r1, 6).numFmt = "$#,##0.00";
    sc(ws, r1, 7, amount, C.body, bg, C.R, C.bottomThin);
    ws.getCell(r1, 7).numFmt = "$#,##0.00";

    sc(ws, r2, 1, "", C.body, bg, C.CC, C.bottomThin);
    sc(ws, r2, 2, "", C.body, bg, C.L, C.bottomThin);
    sc(ws, r2, 3, "", C.body, bg, C.CC, C.bottomThin);
    sc(ws, r2, 4, sz2, C.body, bg, C.CC, C.bottomThin);
    sc(ws, r2, 5, q2, C.body, bg, C.CC, C.bottomThin);
    sc(ws, r2, 6, "", C.body, bg, C.R, C.bottomThin);
    sc(ws, r2, 7, "", C.body, bg, C.R, C.bottomThin);

    ws.mergeCells(r1, 1, r2, 1);
    ws.mergeCells(r1, 2, r2, 2);
    ws.mergeCells(r1, 3, r2, 3);
    ws.mergeCells(r1, 6, r2, 6);
    ws.mergeCells(r1, 7, r2, 7);

    if (imgPath) await embedImage(ws, r1, 3, imgPath, { w: 140, h: 112 });
    row += 2;
  }

  // ═══════════ 合并产品单行（666补件） ═══════════
  async function mergedSingle(imgPath, productName, sz, qty, unitPrice, isAlt) {
    seq++;
    const r = row;
    const rh = 65;
    ws.getRow(r).height = rh;

    const amount = +(qty * unitPrice).toFixed(2);
    const bg = isAlt ? C.alt : C.white;
    const bdr = C.bottomThin;

    sc(ws, r, 1, seq, C.body, bg, C.CC, bdr);
    sc(ws, r, 2, productName, C.body, bg, C.L, bdr);
    sc(ws, r, 3, "", C.body, bg, C.CC, bdr);
    sc(ws, r, 4, sz, C.body, bg, C.CC, bdr);
    sc(ws, r, 5, qty, C.body, bg, C.CC, bdr);
    sc(ws, r, 6, unitPrice, C.body, bg, C.R, bdr);
    ws.getCell(r, 6).numFmt = "$#,##0.00";
    sc(ws, r, 7, amount, C.body, bg, C.R, bdr);
    ws.getCell(r, 7).numFmt = "$#,##0.00";

    if (imgPath) await embedImage(ws, r, 3, imgPath, { w: 140, h: 50 });
    row++;
  }

  function addSubtotal(label, totalAmt) {
    ws.mergeCells(row, 1, row, 5);
    sc(ws, row, 1, label, C.bodyBold, C.white, { horizontal: "right", vertical: "middle" }, C.bottomThin);
    for (let c = 2; c <= 7; c++) sc(ws, row, c, "", C.bodyBold, C.white, C.CC, C.bottomThin);
    sc(ws, row, 7, totalAmt, C.bodyBold, C.white, C.R, C.bottomThin);
    ws.getCell(row, 7).numFmt = "$#,##0.00";
    ws.getRow(row).height = 26;
    row++;
    row++;
  }

  // ═══════════════════════════════════════
  // 1. 7岁男孩
  // ═══════════════════════════════════════
  addSection("Boy, 7 Years  ·  140 cm  ·  5 Styles × 2 Pcs");
  addTableHeader();

  const boy7 = [
    "O1CN01439sFc1aXJR9dCMBt_!!2274733339-0-cib.jpg",
    "O1CN018fU7kQ1aXJR9dl09Y_!!2274733339-0-cib.jpg",
    "O1CN01Aot0Fx1aXJY9ogDvp_!!2274733339-0-cib.jpg",
    "O1CN01rhakve1aXJRFVo2qM_!!2274733339-0-cib.jpg",
    "O1CN01wsHnbc1aXJRAZL50J_!!2274733339-0-cib.jpg",
  ];
  for (let i = 0; i < 5; i++) {
    await singleProduct(`${BASE}/7岁男孩/${boy7[i]}`, "Kids Set", "140cm", 2, 4.50, i % 2 === 1);
  }
  addSubtotal("Boy, 7 Years  Subtotal  ·  10 Pcs", 45.00);

  // ═══════════════════════════════════════
  // 2. 5岁女孩
  // ═══════════════════════════════════════
  addSection("Girl, 5 Years  ·  120 cm  ·  5 Styles × 2 Pcs");
  addTableHeader();

  const girl5 = [
    "O1CN010Af1kh1aXJS6vRZOz_!!2274733339-0-cib.jpg",
    "O1CN01aB2tB81aXJS7xVzgy_!!2274733339-0-cib.jpg",
    "O1CN01dwAVF61aXJS8kO70t_!!2274733339-0-cib.jpg",
    "O1CN01gd2rBe1aXJS4vDEGe_!!2274733339-0-cib.jpg",
    "O1CN01njRSAS1aXJS6AqN7g_!!2274733339-0-cib.jpg",
  ];
  for (let i = 0; i < 5; i++) {
    await singleProduct(`${BASE}/5岁女孩/${girl5[i]}`, "Kids Set", "120cm", 2, 3.80, i % 2 === 1);
  }
  addSubtotal("Girl, 5 Years  Subtotal  ·  10 Pcs", 38.00);

  // ═══════════════════════════════════════
  // 3. 15个月-2岁男孩
  // ═══════════════════════════════════════
  addSection("Boy, 15M–2Y  ·  7 Products  ·  90 cm + 100 cm Each  (+1 Extra)");
  addTableHeader();

  const g3 = [
    { code: "333", file: "1.jpg", price: 3.45, extra: false },
    { code: "444", file: "2.jpg", price: 3.10, extra: false },
    { code: "555", file: "3.jpg", price: 3.60, extra: false },
    { code: "666", file: "4.jpg", price: 4.65, extra: false },
    { code: "666", file: "4.jpg", price: 4.65, extra: true },
    { code: "777", file: "5.jpg", price: 2.95, extra: false },
    { code: "888", file: "6.jpg", price: 2.65, extra: false },
    { code: "999", file: "7.jpg", price: 2.98, extra: false },
  ];

  let lastFile = "";
  for (let i = 0; i < g3.length; i++) {
    const item = g3[i];
    const imgPath = item.file !== lastFile ? `${BASE}/15个月-2岁男孩/${item.file}` : null;
    lastFile = item.file;
    const label = item.extra ? `${item.code} (Extra)` : item.code;

    if (item.extra) {
      await mergedSingle(imgPath, "Kids Set", "90cm", 1, item.price, i % 2 === 1);
    } else {
      await mergedProduct(imgPath, "Kids Set", "90cm", 1, "100cm", 1, item.price, i % 2 === 1);
    }
  }
  addSubtotal("Boy, 15M–2Y  Subtotal  ·  15 Pcs", 51.41);

  // ═══════════════════════════════════════
  // 4. 1个月婴儿
  // ═══════════════════════════════════════
  addSection("Baby, 1 Month  ·  3 Products, 7 Styles");
  addTableHeader();

  await singleProduct(`${BASE}/1个月婴儿/1.jpg`, "Baby Romper", "0-3M", 3, 8.80, false);
  for (let s = 2; s <= 4; s++) {
    await singleProduct(`${BASE}/1个月婴儿/${s}.jpg`, "Baby Romper", "52cm", 2, 4.00, s % 2 === 1);
  }
  const longNames = [
    "O1CN01Atuesr1LUMkgdVwtZ_!!2218361591302-0-cib.jpg",
    "O1CN01m77qBb1LUMkWZHLzb_!!2218361591302-0-cib.jpg",
    "O1CN01vcRbeF1LUMkYROsun_!!2218361591302-0-cib.jpg",
  ];
  for (let i = 0; i < 3; i++) {
    await singleProduct(`${BASE}/1个月婴儿/${longNames[i]}`, "Baby Romper", "0-3M", 2, 10.00, i % 2 === 1);
  }
  addSubtotal("Baby, 1 Month  Subtotal  ·  15 Pcs", 110.40);

  // ═══════════════════════════════════════
  // 5. 汇总
  // ═══════════════════════════════════════
  ws.mergeCells(row, 1, row, 7);
  sc(ws, row, 1, "", C.body, C.white, C.CC, C.topBorder);
  ws.getRow(row).height = 8;
  row++;

  const summary = [
    { label: "Products Total  ·  50 Pcs", value: 244.81, isGrand: false },
    { label: "Freight  ·  DDP Air  ~15 Days", value: 121.70, isGrand: false },
    { label: "Grand Total", value: 366.51, isGrand: true },
  ];

  summary.forEach((s) => {
    ws.mergeCells(row, 1, row, 5);
    const font = s.isGrand ? C.grandTotal : C.summary;
    ws.getRow(row).height = s.isGrand ? 34 : 26;

    sc(ws, row, 1, s.label, font, C.white, C.R, C.bottomThin);
    for (let c = 2; c <= 6; c++) sc(ws, row, c, "", font, C.white, C.CC, C.bottomThin);
    sc(ws, row, 7, s.value, font, C.white, C.R, C.bottomThin);
    ws.getCell(row, 7).numFmt = "$#,##0.00";
    row++;
  });

  row++;
  ws.mergeCells(row, 1, row, 7);
  sc(ws, row, 1, "Trade Terms: DDP  ·  Air Freight  ·  Transit ~15 Days  ·  Dispatch 1–7 Days  ·  Custom Order MOQ: 500 Pcs/Style", C.note, C.white, C.CC, {});

  ws.pageSetup.orientation = "portrait";
  ws.pageSetup.fitToPage = true;
  ws.pageSetup.fitToWidth = 1;
  ws.pageSetup.margins = { left: 0.4, right: 0.4, top: 0.5, bottom: 0.5 };

  const out = "C:/Users/Administrator/Desktop/Quotation_50Pcs.xlsx";
  await wb.xlsx.writeFile(out);
  console.log("OK:", out);
}

main().catch((e) => { console.error(e); process.exit(1); });
