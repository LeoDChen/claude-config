  tr:hover td { background: #fafbfc; }

  .stage-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 4px; }
  .grade-badge { color: #fff; padding: 2px 7px; border-radius: 3px; font-size: 11px; font-weight: 700; }
  .stage-tag { color: #fff; padding: 2px 7px; border-radius: 3px; font-size: 11px; }
  .tag { display: inline-block; padding: 2px 7px; border-radius: 3px; font-size: 11px; font-weight: 600; }
  .tag.danger { background: #ffe0e0; color: #c0392b; }
  .tag.warn { background: #fff3cd; color: #856404; }
  .tag.info { background: #d1ecf1; color: #0c5460; }
  .tag.ok { background: #d4edda; color: #155724; }
  .q-preview { max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; color: #888; }
  .num-danger { color: #e74c3c; }

  .signal-item { padding: 14px 16px; margin: 8px 0; border-left: 4px solid #e67e22; background: #fffdf0; border-radius: 0 6px 6px 0; }
  .signal-item.critical { border-left-color: #e74c3c; background: #fff5f5; }
  .signal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; font-weight: 600; }
  .signal-reason { margin-bottom: 4px; }
  .signal-q { font-size: 12px; color: #999; font-style: italic; margin: 4px 0; }
  .signal-meta { font-size: 12px; color: #888; }

  .matrix { display: grid; grid-template-columns: 120px repeat(5, 1fr); gap: 1px; background: #e9ecef; border: 1px solid #e9ecef; border-radius: 6px; overflow: hidden; font-size: 13px; }
  .matrix > * { background: #fff; padding: 10px 8px; text-align: center; }
  .matrix .mhd { background: #f8f9fa; font-weight: 600; }

  .popup-btn { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: var(--red); color: #fff; border: none;
    border-radius: 50px; padding: 14px 24px; font-size: 15px; font-weight: 700; cursor: pointer;
    box-shadow: 0 4px 20px rgba(231,76,60,0.4); transition: all 0.2s; display: flex; align-items: center; gap: 8px; }
  .popup-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(231,76,60,0.5); }
  .popup-btn .cnt { background: #fff; color: var(--red); border-radius: 20px; padding: 2px 10px; font-size: 14px; }

  .modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99999; justify-content: center; align-items: center; }
  .modal.show { display: flex; }
  .modal-box { background: #fff; border-radius: 12px; width: 750px; max-width: 94vw; max-height: 82vh; overflow-y: auto; box-shadow: 0 16px 48px rgba(0,0,0,0.3); }
  .modal-hd { display: flex; justify-content: space-between; align-items: center; padding: 18px 24px; border-bottom: 1px solid #eee; font-weight: 700; font-size: 16px; position: sticky; top: 0; background: #fff; border-radius: 12px 12px 0 0; }
  .modal-close { cursor: pointer; font-size: 26px; color: #bbb; border: none; background: none; padding: 0 6px; }
  .modal-close:hover { color: #333; }
  .modal-bd { padding: 20px 24px; }

  .tip { font-size: 12px; color: #999; padding: 10px; background: #f8f9fa; border-radius: 4px; margin-top: 16px; }

  @media (max-width: 768px) {
    .cards { grid-template-columns: repeat(2, 1fr); }
    .matrix { font-size: 11px; }
  }
</style>
</head>
<body>
<div class="container">

<div class="topbar">
  <h1><span class="dot"></span>小星星 OKKI 客户看板</h1>
  <div class="meta"><span>${today}</span><span>生成于 ${timeStr}</span></div>
</div>

<div class="cards">
  ${cardData.map(c => '<div class="card"><div class="num" style="color:' + c.color + '">' + c.num + '</div><div class="lbl">' + c.label + '</div></div>').join('')}
</div>

${signals.length > 0 ? `
<div class="panel">
  <div class="panel-hd orange">⚡ 行动信号 — ${signals.length} 个客户需关注</div>
  <div class="panel-bd">${signalItems}</div>
</div>
` : ''}

<div class="panel">
  <div class="panel-hd red">📋 客户分类详情 (双轴: 生命周期 × 质量等级)</div>
  <div class="panel-bd" style="overflow-x:auto;">
    <table>
      <thead><tr><th>阶段</th><th>客户</th><th>国家</th><th>质量</th><th>距今</th><th>客户静默</th><th>最后提问</th><th>回复质量</th><th>间隔</th><th>沉默状态</th></tr></thead>
      <tbody>${stageRows}</tbody>
    </table>
  </div>
</div>

<div class="panel">
  <div class="panel-hd">📐 双轴矩阵 (阶段 × 等级)</div>
  <div class="panel-bd">
    <div class="matrix">
      <div class="mhd">阶段 \\ 等级</div>
      <div class="mhd">S</div><div class="mhd">A</div><div class="mhd">B</div><div class="mhd">C</div><div class="mhd">D</div>
      ${['待回复', '初询沟通', '报价已发', '谈判/样品', 'PI已发', '订单执行中', '已签收', '售后'].map(s => {
        const items = byStage[s] || [];
        const grades = { S: [], A: [], B: [], C: [], D: [] };
        for (const e of items) grades[e.grade].push(e);
        return '<div>' + s + '</div>' + ['S', 'A', 'B', 'C', 'D'].map(g => '<div>' + (grades[g].length || '-') + '</div>').join('');
      }).join('')}
    </div>
  </div>
</div>

<div class="tip">
  💡 <b>分类体系：</b>双轴模型 v2 — 生命周期(8阶段+沉默副状态) × 质量等级(S/A/B/C/D)。质量等级为自动判定，标注"auto"的需人工确认。
  提问检测：英文问号/what/how/can you等 + 中文吗/呢/？/报价/样品等。回复质量：未回复 / 敷衍(<15字) / 简短(15-50字) / 充分(≥50字)。
</div>

</div>

<button class="popup-btn" onclick="document.getElementById('modal').classList.add('show')">
  ⚡ 信号速览 <span class="cnt">${signals.length}</span>
</button>

<div id="modal" class="modal" onclick="if(event.target===this)this.classList.remove('show')">
  <div class="modal-box">
    <div class="modal-hd">
      <span>⚡ 行动信号速览 — ${signals.length} 个待处理</span>
      <button class="modal-close" onclick="document.getElementById('modal').classList.remove('show')">✕</button>
    </div>
    <div class="modal-bd">
      ${signals.length === 0 ? '<p style="color:#888;text-align:center;">✅ 当前无紧急行动信号</p>' : ''}
      ${signals.map((e, i) => {
        let advice = '';
        if (e.questionUnanswered) advice = '24h内必须回复客户提问';
        else if (e.ourResponseQuality.startsWith('敷衍回复')) advice = '补充详细信息或发送产品目录补救';
        else if (e.responseGapDays > 3) advice = '回复间隔过长，立即联系确认需求';
        else if (e.silenceState) advice = '客户进入' + e.silenceState + '，按策略触达';
        else advice = '查看详情，评估下一步';
        return '<div class="signal-item ' + (e.questionUnanswered ? 'critical' : 'warn') + '">'
          + '<div class="signal-header"><span>' + (i + 1) + '. ' + e.name + ' (' + (e.country || '??') + ')</span>'
          + '<span><span class="grade-badge" style="background:' + (gradeColors[e.grade] || '#888') + '">' + e.grade + '</span> ' + e.stageLabel + '</span></div>'
          + '<div class="signal-reason">' + e.actionSignals.map(s => '<span class="tag danger">' + s + '</span>').join(' ') + '</div>'
          + '<div class="action-detail">📌 ' + advice + '</div>'
          + (e.lastCustQuestion ? '<div class="signal-q">❓ ' + e.lastCustQuestion.substring(0, 120) + '</div>' : '')
          + '<div class="signal-meta">💬 ' + e.ourResponseQuality + ' | 静默: ' + (e.lastCustomerMsgDays === '-' ? 'N/A' : e.lastCustomerMsgDays + 'd') + ' | ' + e.realMsgs + '条消息</div>'
          + '</div>';
      }).join('')}
      <div class="tip">按 <b>ESC</b> 或点击背景关闭</div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('keydown', e => { if (e.key === 'Escape') document.getElementById('modal').classList.remove('show'); });
</script>

</body>
</html>`;

  const outPath = path.join(__dirname, '..', 'output', 'action_signals_' + today + '.html');
  fs.writeFileSync(outPath, html, 'utf-8');
  console.log('弹窗看板 → ' + outPath);
}
