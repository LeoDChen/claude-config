function slideBase(slide, title, subtitle) {
  slide.background = { fill: C.bg };
  slide.addShape(pptx.ShapeType.rect, {
    x: 0, y: 0, w: "100%", h: 0.85,
    fill: { color: C.navy },
  });
  slide.addText(title, {
    x: 0.6, y: 0.1, w: "90%", h: 0.6,
    fontSize: 22, fontFace: "Microsoft YaHei", color: C.white, bold: true,
  });
  if (subtitle) {
    slide.addText(subtitle, {
      x: 0.6, y: 1.0, w: "90%", h: 0.4,
      fontSize: 12, fontFace: "Microsoft YaHei", color: C.gray,
    });
  }
}

function imgCard(slide, x, y, w, h, imgPath, label) {
  slide.addImage({ path: imgPath, x, y, w, h, sizing: { type: "contain", w, h } });
  slide.addText(label, {
    x, y: y + h + 0.02, w, h: 0.25,
    fontSize: 8, fontFace: "Microsoft YaHei", color: C.gray, align: "center",
  });
}

function metricCard(slide, x, y, value, label, color) {
  slide.addShape(pptx.ShapeType.roundRect, {
    x, y, w: 2.15, h: 0.65,
    fill: { color: C.white },
    shadow: { type: "outer", blur: 3, offset: 1, color: "CBD5E0", opacity: 0.25 },
    rectRadius: 0.05,
  });
  slide.addText(value, {
    x, y: y + 0.03, w: 2.15, h: 0.35,
    fontSize: 16, fontFace: "Microsoft YaHei", color: color || C.blue, bold: true, align: "center",
  });
  slide.addText(label, {
    x, y: y + 0.38, w: 2.15, h: 0.22,
    fontSize: 9, fontFace: "Microsoft YaHei", color: C.gray, align: "center",
  });
}

function insightBox(slide, x, y, w, h, text, bgColor) {
  slide.addShape(pptx.ShapeType.roundRect, {
    x, y, w, h,
    fill: { color: bgColor || C.light },
    rectRadius: 0.08,
  });
  slide.addText(text, {
    x: x + 0.2, y: y + 0.08, w: w - 0.4, h: h - 0.16,
    fontSize: 11, fontFace: "Microsoft YaHei", color: C.dark, lineSpacingMultiple: 1.4,
