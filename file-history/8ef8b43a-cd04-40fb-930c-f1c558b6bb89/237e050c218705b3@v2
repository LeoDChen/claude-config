// ── Helpers ──
function slideBase(slide, title, subtitle) {
  slide.background = { fill: C.bg };
  slide.addShape(pptx.ShapeType.rect, {
    x: 0, y: 0, w: "100%", h: 0.85,
    fill: { color: C.navy },
  });
  slide.addText(title, {
    x: 0.6, y: 0.1, w: "90%", h: 0.6,
    fontSize: 22, fontFace: "Microsoft YaHei", color: C.white, bold: true,
  });
  if (subtitle) {
    slide.addText(subtitle, {
      x: 0.6, y: 1.0, w: "90%", h: 0.4,
      fontSize: 12, fontFace: "Microsoft YaHei", color: C.gray,
    });
  }
}

function placeholderBox(slide, x, y, w, h, label) {
  slide.addShape(pptx.ShapeType.rect, {
    x, y, w, h,
    fill: { color: "EDF2F7" },
    line: { color: C.accent, width: 1.5, dashType: "dash" },
  });
  slide.addText(label, {
    x, y, w, h,
    fontSize: 11, fontFace: "Microsoft YaHei", color: C.gray,
    align: "center", valign: "middle",
  });
}

function keyMetric(slide, x, y, value, label, color) {
  slide.addText(value, {
    x, y, w: 2.2, h: 0.6,
    fontSize: 28, fontFace: "Microsoft YaHei", color: color || C.blue,
    bold: true, align: "center",
  });
  slide.addText(label, {
    x, y: y + 0.55, w: 2.2, h: 0.4,
    fontSize: 11, fontFace: "Microsoft YaHei", color: C.gray, align: "center",
  });
}

