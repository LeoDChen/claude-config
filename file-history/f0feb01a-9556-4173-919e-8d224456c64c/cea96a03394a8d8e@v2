{
  "hooks": {
    "SessionStart": [{
      "matcher": ".*",
      "hooks": [{
        "type": "command",
        "command": "node -e \"const fs=require('fs');const f='d:/ClaudeWorkspace/08_客户跟进/Okki/STATE.md';const s=fs.existsSync(f)?fs.readFileSync(f,'utf8'):'';console.log('\\n=== OKKI STATE.md ===\\n'+s.slice(0,2000)+'\\n=======================\\n')\""
      }]
    }],

    "Stop": [{
      "matcher": ".*",
      "hooks": [{
        "type": "command",
        "command": "node -e \"const fs=require('fs');const f='d:/ClaudeWorkspace/08_客户跟进/Okki/STATE.md';if(fs.existsSync(f)){const c=fs.readFileSync(f,'utf8');const ts=new Date().toISOString().slice(0,16).replace('T',' ');const n=c.replace(/最后更新.*/,'最后更新：'+ts);if(n!==c)fs.writeFileSync(f,n)};console.log('')\""
      }]
    }]
  }
}
