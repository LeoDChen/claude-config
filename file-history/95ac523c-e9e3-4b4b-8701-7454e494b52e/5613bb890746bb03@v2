const { chromium } = require('playwright');

(async () => {
  const browser = await chromium.connectOverCDP('http://127.0.0.1:9222');
  const page = browser.contexts()[0].pages().find(p => p.url().includes('xiaoman'));

  // Wait for the iframe to load
  const iframeElement = await page.waitForSelector('iframe#talk-tm-iframe', { timeout: 10000 });
  console.log('iframe found');

  // Wait for iframe content
  await page.waitForTimeout(3000);

  // Now access frames - the iframe should have loaded
  const frames = page.frames();
  console.log('Frames count:', frames.length);

  for (const f of frames) {
    console.log('Frame URL:', (f.url() || '(empty)').substring(0, 200));
    try {
      const html = await f.evaluate(() => document.body?.innerHTML || '').catch(e => 'ERROR: ' + e.message);
      if (html.length > 100) {
        console.log('  HTML len:', html.length);
        // Check for chat content
        const text = await f.evaluate(() => document.body?.innerText || '').catch(() => '');
        if (text.includes('rehema') || text.includes('kiseyu')) {
          console.log('  === FOUND REHEMA ===');
          const idx = text.toLowerCase().indexOf('rehema');
          console.log(text.substring(Math.max(0, idx - 500), idx + 1500));
        }
        if (text.length > 10) {
          console.log('  Text preview:', text.substring(0, 2000));
        }
      }
    } catch(e) {
      console.log('  Error:', e.message.substring(0, 100));
    }
  }

})().catch(err => {
  console.log('Fatal:', err.message);
});
