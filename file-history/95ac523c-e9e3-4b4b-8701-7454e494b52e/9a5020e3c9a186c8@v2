const { chromium } = require('playwright');

(async () => {
  const browser = await chromium.connectOverCDP('http://127.0.0.1:9222');
  const page = browser.contexts()[0].pages().find(p => p.url().includes('xiaoman'));

  // Find the iframe with chat content
  const frame = page.frames().find(f => f.url().includes('onetalk') || f.url().includes('alibaba'));
  if (!frame) {
    console.log('未找到聊天框架');
    return;
  }

  console.log('聊天框架URL:', frame.url().substring(0, 200));

  // Get all text from frame
  const text = await frame.evaluate(() => document.body.innerText);
  console.log('=== 框架文本 ===\n', text);

  // Check if Rehema's conversation is clickable
  const rehemaEl = await frame.evaluate(() => {
    const all = document.querySelectorAll('*');
    const items = [];
    all.forEach(el => {
      if (el.textContent.includes('rehema') || el.textContent.includes('kiseyu')) {
        const rect = el.getBoundingClientRect();
        if (rect.width > 0 && rect.height > 0) {
          items.push({
            tag: el.tagName,
            text: el.textContent.trim().substring(0, 100),
            class: el.className?.substring(0, 60),
            rect: { top: rect.top, left: rect.left, width: rect.width, height: rect.height }
          });
        }
      }
    });
    return items;
  });
  console.log('\n=== Rehema元素 ===');
  rehemaEl.forEach(e => console.log(JSON.stringify(e)));

  // If found, click it
  if (rehemaEl.length > 0) {
    const target = rehemaEl[rehemaEl.length - 1]; // innermost element
    console.log('正在点击Rehema...');
    const box = target.rect;
    await frame.click(`text=${target.text.substring(0, 30)}`);
    await page.waitForTimeout(2000);

    // Read the frame content again after clicking
    const newText = await frame.evaluate(() => document.body.innerText);
    console.log('\n=== 点击后框架内容 ===\n', newText);
  }

})().catch(err => {
  console.log('Error:', err.message?.substring(0, 200));
});
