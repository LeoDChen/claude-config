const { chromium } = require('playwright');

(async () => {
  const browser = await chromium.connectOverCDP('http://localhost:9222');
  const pages = browser.contexts()[0].pages();
  const page = pages[0];
  const client = await page.context().newCDPSession(page);

  const targets = await client.send('Target.getTargets');
  const ot = targets.targetInfos.find(t => t.url.includes('onetalk') && t.type === 'iframe');
  if (!ot) { console.log('onettalk iframe not found'); process.exit(1); }
  const { sessionId } = await client.send('Target.attachToTarget', { targetId: ot.targetId, flatten: false });

  let results = [];
  client.on('Target.receivedMessageFromTarget', (msg) => {
    if (msg.sessionId !== sessionId) return;
    try {
      const response = JSON.parse(msg.message);
      if (response.id && response.result) {
        const val = response.result.result ? response.result.result.value : null;
        if (val) results.push({ id: response.id, val: JSON.parse(val) });
      }
    } catch (e) {}
  });

  const expr = `
    (async function() {
      var r = {};

      // Step 1: Explore _imsdk more carefully
      var imsdk = window._imsdk;
      r.imsdkType = typeof imsdk;
      r.imsdkIsNull = imsdk === null;

      // Check if _imsdk and _imBaaSSDK are related
      var baaS = window._imBaaSSDK;
      r.imsdkIsBaaS = imsdk === baaS;
      r.imsdkProto = imsdk ? Object.getPrototypeOf(imsdk).constructor.name : 'N/A';

      // Try to list ALL properties of _imsdk (including inherited)
      if (imsdk) {
        var allKeys = [];
        for (var k in imsdk) allKeys.push(k);
        r.imsdkAllKeys = allKeys.slice(0, 30);

        // Try calling methods to see if they exist
        try { r.hasGetAuthService = typeof imsdk.getAuthService === 'function'; } catch(e) {}
        try { r.hasGetMessageService = typeof imsdk.getMessageService === 'function'; } catch(e) {}
        try { r.hasGetConversationService = typeof imsdk.getConversationService === 'function'; } catch(e) {}
      }

      // Step 2: Try to reconnect the SDK
      var authSvc = baaS.getAuthService();
      if (authSvc) {
        r.authMethods = [];
        for (var k in authSvc) {
          if (typeof authSvc[k] === 'function') r.authMethods.push(k);
        }

        // Check if there's a login or connect method
        r.hasLogin = typeof authSvc.login === 'function';
        r.hasConnect = typeof authSvc.connect === 'function';
        r.hasReconnect = typeof authSvc.reconnect === 'function';
        r.hasRelogin = typeof authSvc.relogin === 'function';

        // Try calling login (might need credentials)
        if (r.hasLogin) {
          try {
            // The login might auto-use stored token
            var loginResult = authSvc.login();
            r.loginResult = loginResult;
            // Wait a bit and re-check
            await new Promise(function(res) { setTimeout(res, 2000); });
            r.afterLoginStatus = authSvc.connectionStatus;
          } catch(e) {
            r.loginError = e.message;
          }
        }
      }

      // Step 3: Try to find socket through the event service
      var eventSvc = baaS.getEventService();
      if (eventSvc) {
        var evtKeys = [];
        for (var k in eventSvc) {
          if (typeof eventSvc[k] !== 'function') evtKeys.push(k);
        }
        r.eventSvcProps = evtKeys;
      }

      // Step 4: Look at what's on the window that might be useful
      var windowKeys = Object.keys(window).filter(function(k) {
        return k.startsWith('_') || k.startsWith('im') || k.startsWith('IM') || k.includes('socket') || k.includes('Socket') || k.includes('ws') || k.includes('WS') || k.includes('lwp') || k.includes('LWP');
      });
      r.relevantWindowKeys = windowKeys;

      // Step 5: Check if the SDK has an internal message channel setup
      // Try to intercept messages by wrapping postMessage
      r.hasPostMessage = typeof postMessage === 'function';

      return JSON.stringify(r, null, 2);
    })()
  `;

  console.log('Exploring SDK + trying reconnect...');
  await client.send('Target.sendMessageToTarget', {
    sessionId: sessionId,
    message: JSON.stringify({
      id: 1,
      method: 'Runtime.evaluate',
      params: { expression: expr, awaitPromise: true }
    })
  });

  await new Promise(r => setTimeout(r, 8000));

  if (results.length > 0) {
    console.log(results[0].val);
  } else {
    console.log('No response');
  }

  process.exit(0);
})().catch(e => { console.error(e.message); process.exit(1); });
