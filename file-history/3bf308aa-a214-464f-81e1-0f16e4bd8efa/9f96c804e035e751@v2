## 五、factor_baselines.json 结构

```json
{
  "customer_123": {
    "stage": "报价已发",
    "stage_updated": "2026-05-15",
    "baselines": {
      "S1": null,
      "S2": "2026-05-15",
      "S3": null,
      "S4": null,
      "S5a_A": null,
      "S5a_B": null,
      "S5b": null,
      "S6": null,
      "S7a": null,
      "S7b": null,
      "S8": null,
      "S9": null
    },
    "meta": {
      "transit_days": null,
      "customer_tier": "B",
      "committed_ship_date": null,
      "has_address": false,
      "customer_type": "大货",
      "repurchase_cycle_days": null
    }
  }
