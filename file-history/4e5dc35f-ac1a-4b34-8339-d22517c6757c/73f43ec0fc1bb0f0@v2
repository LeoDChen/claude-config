  .kpi-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-bottom: 20px; }
  .kpi { color: #fff; padding: 14px 12px; border-radius: 8px; text-align: center; }
  .kpi .num { font-size: 28px; font-weight: 700; }
  .kpi .lbl { font-size: 11px; opacity: 0.9; }

  .card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-bottom: 16px; }
  .card-hd { background: var(--bg-tertiary); padding: 10px 14px; font-weight: 600; font-size: 13px; border-bottom: 1px solid var(--border); }
  .card-hd span { font-weight: normal; font-size: 11px; color: var(--text-secondary); }

  table.mx { width: 100%; border-collapse: collapse; font-size: 12px; }
  table.mx th { padding: 6px 8px; border: 1px solid var(--border); background: var(--bg-tertiary); font-weight: 600; }
  table.mx td { border: 1px solid var(--border); }
  table.mx td.rl { text-align: left; font-weight: 600; padding: 6px 8px; }

  .flex { display: flex; gap: 16px; margin-bottom: 16px; }
  .flex-1 { flex: 1; }
  .flex-320 { flex: 0 0 340px; }

  .silence-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; border-bottom: 1px solid var(--border); cursor: pointer; }
  .silence-detail { display: none; padding: 8px 14px; border-bottom: 1px solid var(--border); }

  table.sub { width: 100%; border-collapse: collapse; font-size: 12px; }
  table.sub th { padding: 8px; border: 1px solid var(--border); text-align: left; background: var(--bg-tertiary); font-weight: 600; }
  table.sub td { padding: 8px; border: 1px solid var(--border); }
  table.sub td.nc { text-align: center; }

  .trend-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid var(--border); }
  .trend-row .det { font-size: 11px; color: var(--text-secondary); }

  .footer { margin-top: 24px; padding: 14px; border-top: 1px solid var(--border); font-size: 11px; color: var(--text-secondary); text-align: center; }
  .footer a { color: var(--accent); }
</style>
</head>
<body>

<h1>OKKI 客户管道看板</h1>
<div class="subtitle">生成时间：${today} | 数据源：s1_enhanced_full.json + tm_conversations_latest.json | 全覆盖 ${totalCustomers} 客户</div>

<!-- KPI -->
<div class="kpi-grid">
  <div class="kpi" style="background:#1a5276;"><div class="num">${totalCustomers}</div><div class="lbl">总客户</div></div>
  <div class="kpi" style="background:#1a5276;"><div class="num">${active3d}</div><div class="lbl">3天活跃</div></div>
  <div class="kpi" style="background:#c0392b;"><div class="num">${silent90d}</div><div class="lbl">超90天无互动</div></div>
  <div class="kpi" style="background:#e67e22;"><div class="num">${totalUnread}</div><div class="lbl">未读消息</div></div>
  <div class="kpi" style="background:#27ae60;"><div class="num">${changes.up + changes.down + changes.new_}</div><div class="lbl">本期变动</div></div>
  <div class="kpi" style="background:#8e44ad;"><div class="num">${actionNeeded}</div><div class="lbl">需行动</div></div>
</div>

<!-- 双轴矩阵 -->
<div class="card">
  <div class="card-hd">客户双轴矩阵 <span>（生命周期 × 质量）— 点击格子展开客户名单 + 标准动作</span></div>
  <div style="overflow-x:auto;">
    <table class="mx">
      <tr>
        <th style="text-align:left;min-width:80px;">阶段 \\ 等级</th>
        ${QUALITY_ORDER.map(q => `<th>S ${q}</th>`).join('')}
      </tr>
      ${LIFECYCLE_ORDER.map(ls => `<tr>
        <td class="rl">${esc(ls)}</td>
        ${QUALITY_ORDER.map(q => buildCellHTML(ls, q)).join('')}
      </tr>`).join('')}
    </table>
  </div>
  <div style="padding:6px 14px;font-size:10px;color:var(--text-secondary);">
    颜色越深=该格客户越多 | 点击数字弹出详情（标准动作 + 客户名单）
  </div>
</div>

<!-- 静默风险 + 变动 并排 -->
<div class="flex">
  <div class="flex-320 card">
    <div class="card-hd">静默风险分级</div>
    ${buildSilenceSection('deep')}
    ${buildSilenceSection('long')}
    ${buildSilenceSection('mid')}
    ${buildSilenceSection('short')}
    ${buildSilenceSection('active')}
    ${buildSilenceSection('hot')}
  </div>

  <div class="flex-1 card" style="align-self:flex-start;">
    <div class="card-hd">本期变动（相较上次运行）</div>
    <div style="padding:10px 14px;font-size:13px;">
      <div class="trend-row">
        <span>📈 升级</span><strong style="color:#27ae60;">${changes.up}人</strong>
        <span class="det">${changes.upDetail.slice(0, 5).join(', ') || '-'}</span>
      </div>
      <div class="trend-row">
        <span>📉 降级</span><strong style="color:#e74c3c;">${changes.down}人</strong>
        <span class="det">${changes.downDetail.slice(0, 5).join(', ') || '-'}</span>
      </div>
      <div class="trend-row">
        <span>🆕 新进入</span><strong style="color:#3498db;">${changes.new_}人</strong>
        <span class="det">${changes.newDetail.slice(0, 5).join(', ') || '-'}</span>
      </div>
      <div class="trend-row" style="border-bottom:none;">
        <span>⏸️ 流失</span><strong style="color:var(--text-secondary);">${changes.lost}人</strong>
        <span class="det">${changes.lostDetail.slice(0, 5).join(', ') || '-'}</span>
      </div>
    </div>
  </div>
</div>

<!-- 市场分布 -->
<div class="card">
  <div class="card-hd">核心市场管道密度</div>
  <table class="sub">
    <tr><th>市场</th><th>客户数</th><th>S/A级</th><th>需行动</th></tr>
    ${buildMarketRows()}
  </table>
</div>

<div class="footer">
  管道看板 — 脚本自动生成，覆盖全部 ${totalCustomers} 客户 |
  深度分析请新开对话：<code>/okki 深度分析 [客户名]</code> |
  上次生成：${today}
</div>

<script>
// 点击页面任意处关闭弹出的详情
document.addEventListener('click', function(e) {
  if (!e.target.closest('[onclick]') || !e.target.closest('td')) {
    document.querySelectorAll('[id^="detail-"]').forEach(function(el) {
      el.style.display = 'none';
    });
  }
});
</script>
</body>
</html>`;

// 写入文件
const outPath = path.join(OUTPUT, `dashboard_${today}.html`);
fs.writeFileSync(outPath, html, 'utf8');

console.log('Dashboard written to:', outPath);
console.log('Customers:', totalCustomers);
console.log('Matrix cells:', LIFECYCLE_ORDER.length * QUALITY_ORDER.length);
console.log('Active (3d):', active3d);
console.log('Silent (90d+):', silent90d);
console.log('Action needed:', actionNeeded);
