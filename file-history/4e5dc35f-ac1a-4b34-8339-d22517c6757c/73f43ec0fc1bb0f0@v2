/**
 * OKKI 管道看板生成器
 * 读取分类数据 + 会话元数据 → 生成自包含 HTML 看板
 *
 * 用法：node scripts/generate_dashboard.js
 * 输出：output/dashboard_YYYY-MM-DD.html
 */

const fs = require('fs');
const path = require('path');

const ROOT = path.join(__dirname, '..');
const DATA = path.join(ROOT, 'data');
const OUTPUT = path.join(ROOT, 'output');

// ============================================================
// 1. 加载数据
// ============================================================

const enhanced = JSON.parse(fs.readFileSync(path.join(DATA, 's1_enhanced_full.json'), 'utf8'));
const tm = JSON.parse(fs.readFileSync(path.join(DATA, 'tm_conversations_latest.json'), 'utf8'));

// 建立 CID → tm 会话的索引（用于获取 complianceCountryCode 和 daysSinceLastContact）
const tmByCid = {};
for (const c of tm.conversations) {
  tmByCid[c.cid] = c;
}
// 也建一个 name 索引
const tmByName = {};
for (const c of tm.conversations) {
  const key = (c.name || '').toLowerCase().trim();
  tmByName[key] = c;
}

// ============================================================
// 2. 合并数据 + 推导生命周期阶段 & 质量等级
// ============================================================

const CORE_MARKETS = ['SD', 'EG', 'CD', 'ZM', 'CI', 'SA', 'AE'];

// 生命周期阶段定义（排序用）
const LIFECYCLE_ORDER = [
  '待回复', '初询沟通', '报价已发', '谈判/样品',
  'PI已发', '订单执行', '已签收', '售后'
];

const QUALITY_ORDER = ['S', 'A', 'B', 'C', 'D'];

function deriveLifecycle(c) {
  // 按优先级推导生命周期阶段
  if (c.hasOrderSignal && (c.hasPI || c.hasPrice)) return '订单执行';
  if (c.hasPI) return 'PI已发';
  if (c.hasOrderSignal) return '谈判/样品';
  if (c.hasPrice && c.hasQuantity) return '报价已发';
  if (c.hasPrice) return '报价已发';
  if (c.hasSample) return '谈判/样品';
  if (c.hasQuantity || c.customerMsgs > 0) return '初询沟通';
  if (c.realMsgs > 0) return '初询沟通';
  return '待回复';
}

function deriveQuality(c) {
  // 基于信号推导质量等级
  const signals = [
    c.hasPI, c.hasAddress, c.hasOrderSignal, c.hasPrice,
    c.hasSample, c.hasQuantity, c.hasMOQ, c.hasFreight
  ].filter(Boolean).length;
  const isCore = CORE_MARKETS.includes(c.country);

  // S 级：PI+地址+核心市场+高互动
  if (c.hasPI && c.hasAddress && isCore && c.realMsgs > 10) return 'S';
  if (c.hasOrderSignal && c.realMsgs > 20) return 'S';

  // A 级：有明确交易信号
  if (c.hasPI || c.hasOrderSignal) return 'A';
  if (c.hasPrice && c.hasQuantity && c.realMsgs > 5) return 'A';
  if (c.hasSample && c.realMsgs > 10) return 'A';

  // B 级：有询盘信号
  if (signals >= 2 && c.realMsgs > 3) return 'B';
  if (c.hasPrice || c.hasSample || c.hasQuantity) return 'B';
  if (c.realMsgs > 5) return 'B';

  // C 级：有微弱互动
  if (c.realMsgs > 0) return 'C';

  // D 级：无有效互动
  return 'D';
}

function getSilenceTier(days) {
  if (days > 90) return { tier: 'deep', label: '深度静默 90天+', color: '#c0392b', bg: 'rgba(192,57,43,0.08)' };
  if (days > 30) return { tier: 'long', label: '长期静默 30-90天', color: '#e67e22', bg: 'rgba(230,126,34,0.08)' };
  if (days > 14) return { tier: 'mid', label: '中期静默 14-30天', color: '#f39c12', bg: 'rgba(243,156,18,0.08)' };
  if (days > 7) return { tier: 'short', label: '短期静默 7-14天', color: '#3498db', bg: 'rgba(52,152,219,0.08)' };
  if (days >= 3) return { tier: 'active', label: '近期活跃 3-7天', color: '#27ae60', bg: 'rgba(39,174,96,0.08)' };
  return { tier: 'hot', label: '近期活跃 <3天', color: '#27ae60', bg: 'rgba(39,174,96,0.08)' };
}

// 标准跟进动作（按生命周期阶段）
const STANDARD_ACTIONS = {
  '待回复': {
