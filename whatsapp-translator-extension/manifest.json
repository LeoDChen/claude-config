{
  "manifest_version": 3,
  "name": "WhatsApp 实时翻译助手",
  "version": "1.0",
  "description": "使用 DeepSeek API 实时翻译 WhatsApp Web 消息",
  "permissions": ["storage"],
  "host_permissions": ["https://api.deepseek.com/*"],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "WhatsApp 翻译设置"
  }
}
